<div class="page-shell-modern">

  <p class="back-link honk">
    <%= link_to "← Back to profile", user_path(@user) %>
  </p>

  <div class="page-header-modern">
    <div>
      <h1 class="honk">Edit profile</h1>
      <p class="page-subtitle-modern">Update your public profile and technologies.</p>
    </div>
  </div>

  <section class="profile-hero-card compact">
    <div class="profile-hero-main">
      <div class="profile-avatar-wrap">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "profile-avatar profile-avatar-medium" %>
        <% else %>
          <div class="profile-avatar-fallback">
            <%= @user.display_name.to_s.first.upcase %>
          </div>
        <% end %>
      </div>

      <div class="profile-hero-content compact">
        <h2><%= @user.display_name %></h2>
        <p class="muted-text">Editing your public profile</p>
      </div>
    </div>
  </section>

  <div class="content-card auth-card">
    <%= form_with model: @user, html: { multipart: true } do |f| %>

      <% if @user.errors.any? %>
        <div class="form-errors">
          <h2><%= pluralize(@user.errors.count, "error") %> prevented this profile from being saved:</h2>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <section class="content-section">
        <h2 class="section-title">Public profile</h2>

        <div class="field mb-3">
          <%= f.label :display_name, "Display name", class: "form-label" %>
          <%= f.text_field :display_name, class: "form-control" %>
        </div>

        <div class="field mb-3">
          <%= f.label :bio, "Bio", class: "form-label" %>
          <%= f.text_area :bio, rows: 4, class: "form-control", placeholder: "Tell other members a bit about yourself, your background, or what you like to build." %>
        </div>

        <div class="field mb-3">
          <%= f.label :github_url, "GitHub URL", class: "form-label" %>
          <%= f.text_field :github_url, class: "form-control", placeholder: "https://github.com/yourname" %>
        </div>

        <section class="content-subcard">
          <h2 class="section-title">Technologies</h2>
          <p class="muted-text">Select the technologies you use so other members can better understand your stack.</p>

          <%= hidden_field_tag "user[technology_ids][]", "" %>

          <div class="tech-grid">
            <% Technology.order(:name).each do |tech| %>
              <label class="tech-option" for="user_technology_<%= tech.id %>">
                <%= check_box_tag "user[technology_ids][]",
                    tech.id,
                    @user.technology_ids.include?(tech.id),
                    class: "form-check-input",
                    id: "user_technology_#{tech.id}" %>
                <span><%= tech.name %></span>
              </label>
            <% end %>
          </div>
        </section>

        <% if @user.avatar.attached? %>
          <div class="field mb-3">
            <label class="form-label">Current avatar</label>
            <div class="avatar-preview">
              <%= image_tag @user.avatar, class: "profile-avatar" %>
            </div>
          </div>
        <% end %>

        <div class="field mb-3">
          <%= f.label :avatar, "Avatar", class: "form-label" %>
          <%= f.file_field :avatar, accept: "image/*", class: "form-control" %>
        </div>

      </section>

      <div class="actions mt-4">
        <%= f.submit "Save profile", class: "btn btn-orange w-100" %>
      </div>

    <% end %>
  </div>
</div>

<style>
  :root {
    --navy: #0a0f1f;
    --navy-light: #11182e;
    --orange: #ff7a00;
    --grey-light: #d1d5db;
    --grey-mid: #9ca3af;
    --white: #ffffff;
  }

  body {
    background: var(--navy);
    color: var(--white);
  }

  /* --- CENTRAGE GLOBAL --- */
  .page-shell-modern {
    max-width: 700px;
    margin: 0 auto;
    padding: 40px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-header-modern {
    width: 100%;
    max-width: 600px;
    text-align: center;
    margin-bottom: 20px;
  }

  .profile-hero-card.compact {
    width: 100%;
    max-width: 600px;
    margin: 0 auto 24px auto;
    display: flex;
    justify-content: center;
    background-color: var(--navy-light);
  }

  .auth-card {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  .content-section,
  .content-subcard {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  /* --- TYPO + STYLE --- */
  .honk {
    font-family: "Honk", system-ui;
    font-optical-sizing: auto;
    font-weight: 400;
    font-style: normal;
    font-variation-settings: "MORF" 15, "SHLN" 50;
  }

  .back-link a {
    color: var(--grey-light);
    text-decoration: none;
  }
  .back-link a:hover {
    color: var(--orange);
  }

  .page-subtitle-modern {
    color: var(--grey-light);
  }

  .profile-avatar-medium {
    width: 70px;
    height: 70px;
    border-radius: 12px;
    object-fit: cover;
  }

  .profile-avatar-fallback {
    width: 70px;
    height: 70px;
    border-radius: 12px;
    background: var(--orange);
    color: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 28px;
  }

  .auth-card {
    background: var(--navy-light);
    padding: 32px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .form-label {
    color: var(--grey-light);
    font-weight: 600;
  }

  .form-control {
    background: #0d1326;
    border: 1px solid var(--grey-mid);
    color: var(--white);
    border-radius: 10px;
    padding: 12px;
  }

  .form-control:focus {
    border-color: var(--orange);
    box-shadow: 0 0 0 0.25rem rgba(255, 122, 0, 0.35);
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
    margin-top: 12px;
  }

  .tech-option {
    background: #0d1326;
    border: 1px solid var(--grey-mid);
    padding: 10px 12px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: 0.2s;
  }

  .tech-option:hover {
    border-color: var(--orange);
  }

  .form-check-input {
    accent-color: var(--orange);
  }

  .btn-orange {
    background: var(--orange);
    color: var(--navy);
    font-weight: 700;
    padding: 12px;
    border-radius: 10px;
    border: none;
  }

  .btn-orange:hover {
    background: #ff8f26;
  }
</style>