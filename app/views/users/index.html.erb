<div class="page-shell layout-container builders-page">

  <div class="page-intro">
    <h1 class="title-xl">Browse builders</h1>
    <p class="page-subtitle">
      Discover profiles and find people by stack.
    </p>
  </div>

  <div class="search-hero">
    <%= form_with url: users_path, method: :get, local: true, class: "builders-search-bar" do %>
      <div class="search-input-wrap">
        <%= text_field_tag :q,
          params[:q],
          placeholder: "Search builders...",
          class: "search-input" %>
        <span class="search-input-icon">⌕</span>
      </div>

      <%= select_tag :stack,
        options_for_select(
          [["All stacks", ""]] + Technology::CATEGORIES.map { |category| [category.humanize, category] },
          params[:stack]
        ),
        class: "search-select" %>

      <%= submit_tag "Search", class: "btn btn-profile btn-md" %>
    <% end %>
  </div>

  <% if @users.any? %>
    <div class="builders-grid">
      <% @users.each do |user| %>
        <article class="builder-card">
          <div class="builder-card-top">
            <div class="builder-card-identity">
              <% if user.avatar.attached? %>
                <%= image_tag user.avatar, class: "builder-avatar", alt: user.display_name %>
              <% else %>
                <div class="builder-avatar-fallback">
                  <%= user.display_name.to_s.first&.upcase || "?" %>
                </div>
              <% end %>

              <div class="builder-card-heading">
                <h2 class="builder-card-title">
                  <%= link_to(user.display_name.presence || "Anonymous", user_path(user)) %>
                </h2>

                <p class="builder-card-subtitle">
                  <%= user.github_url.present? ? user.github_url.gsub("https://", "").gsub("http://", "") : "No GitHub yet" %>
                </p>
              </div>
            </div>
          </div>

          <p class="builder-card-bio">
            <%= truncate(user.bio.presence || "No bio yet.", length: 120) %>
          </p>

          <div class="tech-list">
            <% if user.technologies.any? %>
              <% user.technologies.each do |technology| %>
                <span class="tech-badge"><%= technology.name %></span>
              <% end %>
            <% else %>
              <span class="muted-text">No technologies yet</span>
            <% end %>
          </div>

          <div class="builder-card-footer">
            <span class="muted-text">
              <%= pluralize(user.technologies.count, "tech") %>
            </span>

            <%= link_to "View profile", user_path(user), class: "btn btn-profile btn-sm" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <h2 class="title-lg">No builders found</h2>
      <p class="page-subtitle">Try another search or stack filter.</p>
    </div>
  <% end %>

</div>
