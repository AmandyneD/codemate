<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Codemate" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav style="padding: 12px; border-bottom: 1px solid #ddd; margin-bottom: 20px;">
      <%= link_to "Codemate", root_path %>

      <% if user_signed_in? %>
        |
        <span>Connected as <strong><%= current_user.display_name.presence || current_user.email %></strong></span>
        |
        <%= link_to "My projects", my_projects_path %>
        |
        <%= link_to "New project", new_project_path %>
        |
        <%= link_to "Edit account", edit_user_registration_path %>
        |
        <%= button_to "Logout", destroy_user_session_path, method: :delete, style: "display:inline-block; margin-left: 8px;" %>
      <% else %>
        |
        <%= link_to "Sign up", new_user_registration_path %>
        |
        <%= link_to "Login", new_user_session_path %>
      <% end %>
    </nav>

    <% if notice.present? %>
      <div class="notice"><%= notice %></div>
    <% end %>

    <% if alert.present? %>
      <div class="alert"><%= alert %></div>
    <% end %>

    <%= yield %>
  </body>
</html>
