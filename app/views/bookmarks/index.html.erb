<div class="page-shell-centered">

  <div class="page-header-centered">
    <h1 class="honk">My favorite projects</h1>
    <p class="page-subtitle-modern">Projects you saved to revisit later.</p>
  </div>

  <div class="content-card-centered">

    <% if @favorite_projects.any? %>
      <div class="project-list-centered">
        <% @favorite_projects.each do |project| %>
          <%= link_to project_path(project), class: "project-row-card-centered" do %>
            <div class="project-row-card-content">
              <div class="project-row-card-main">
                <strong><%= project.title %></strong>
                <div class="muted-text"><%= project.short_description %></div>
              </div>

              <div class="project-row-card-meta">
                <span class="badge-centered"><%= project.status.capitalize %></span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="muted-text text-center">You have no favorite projects yet.</p>
    <% end %>

  </div>
</div>

<style>
  :root {
    --navy: #0a0f1f;
    --navy-light: #11182e;
    --orange: #ff7a00;
    --grey-light: #d1d5db;
    --grey-mid: #9ca3af;
    --white: #ffffff;
  }

  body {
    background: var(--navy);
    color: var(--white);
  }

  /* --- PAGE CENTRÉE --- */
  .page-shell-centered {
    max-width: 700px;
    margin: 0 auto;
    padding: 40px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-header-centered {
    text-align: center;
    margin-bottom: 32px;
  }

  .honk {
    font-family: "Honk", system-ui;
    font-variation-settings: "MORF" 15, "SHLN" 50;
  }

  .page-subtitle-modern {
    color: var(--grey-light);
  }

  /* --- CARD PRINCIPALE --- */
  .content-card-centered {
    width: 100%;
    max-width: 600px;
    background: var(--navy-light);
    padding: 32px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 10px 30px rgba(0,0,0,0.25);
  }

  /* --- LISTE DES PROJETS --- */
  .project-list-centered {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .project-row-card-centered {
    display: block;
    background: #0d1326;
    padding: 16px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.08);
    transition: 0.2s;
  }

  .project-row-card-centered:hover {
    border-color: var(--orange);
    background: rgba(255,122,0,0.05);
  }

  .project-row-card-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-row-card-main strong {
    font-size: 17px;
  }

  .muted-text {
    color: var(--grey-light);
    font-size: 14px;
  }

  .badge-centered {
    background: var(--orange);
    color: var(--navy);
    padding: 4px 10px;
    border-radius: 8px;
    font-weight: 700;
  }

  .text-center {
    text-align: center;
  }
</style>