<div class="page-shell">
  <p class="back-link">
    <%= link_to "← Back to profile", user_path(@user) %>
  </p>

  <div class="page-header">
    <div>
      <h1>Edit profile</h1>
      <p class="page-subtitle">Update your public profile and technologies.</p>
    </div>
  </div>

  <div class="content-card">
    <%= form_with model: @user, html: { multipart: true } do |f| %>
      <% if @user.errors.any? %>
        <div class="form-errors">
          <h2><%= pluralize(@user.errors.count, "error") %> prevented this profile from being saved:</h2>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <section class="content-section">
        <h2>Public profile</h2>

        <div class="field">
          <%= f.label :display_name, "Display name" %>
          <%= f.text_field :display_name %>
        </div>

        <div class="field">
          <%= f.label :bio, "Bio" %>
          <%= f.text_area :bio, rows: 4, placeholder: "Tell other members a bit about yourself, your background, or what you like to build." %>
        </div>

        <div class="field">
          <%= f.label :github_url, "GitHub URL" %>
          <%= f.text_field :github_url, placeholder: "https://github.com/yourname" %>
        </div>

        <div class="field">
          <%= f.label :avatar, "Avatar" %>
          <%= f.file_field :avatar, accept: "image/*" %>
        </div>

        <% if @user.avatar.attached? %>
          <div class="field">
            <label>Current avatar</label>
            <div class="avatar-preview">
              <%= image_tag @user.avatar, class: "profile-avatar" %>
            </div>
          </div>
        <% end %>
      </section>

      <section class="content-section">
        <h2>Technologies</h2>
        <p class="muted-text">Select the technologies you use so other members can better understand your stack.</p>

        <%= hidden_field_tag "user[technology_ids][]", "" %>

        <div class="tech-grid">
          <% Technology.order(:name).each do |tech| %>
            <label class="tech-option" for="user_technology_<%= tech.id %>">
              <%= check_box_tag "user[technology_ids][]",
                  tech.id,
                  @user.technology_ids.include?(tech.id),
                  class: "form-check-input",
                  id: "user_technology_#{tech.id}" %>
              <span><%= tech.name %></span>
            </label>
          <% end %>
        </div>
      </section>

      <div class="actions mt-4">
        <%= f.submit "Save profile", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
