<div class="page-shell-modern">
  <div class="page-header-modern mb-4">
    <div>
      <h1 class="page-title honk">New project</h1>
      <p class="page-subtitle-modern">Create a project and start building your team.</p>
    </div>
  </div>

  <div class="project-form-card" style="color: black">
    <%= render "form", project: @project %>
  </div>

  <p class="back-link-modern mt-4">
    <%= link_to "← Back to projects", projects_path, class: "back-link-modern" %>
  </p>
</div>
