<div class="page-shell">
  <div class="page-header">
    <div>
      <h1>My projects</h1>
      <p class="page-subtitle">Manage your drafts, published projects, and collaborations.</p>
    </div>

    <%= link_to "Create a project", new_project_path, class: "btn btn-primary" %>
  </div>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Projects I created</h2>
      <p class="muted-text">Includes drafts and published projects.</p>
    </div>

    <% if @owned_projects.any? %>
      <div class="projects-grid">
        <% @owned_projects.each do |project| %>
          <article class="project-card">
            <div class="project-card-top">
              <span class="badge"><%= project.status.capitalize %></span>
              <span class="badge badge-light"><%= project.category.to_s.humanize %></span>
            </div>

            <h3><%= link_to project.title, project_path(project), class: "project-card-title" %></h3>
            <p class="project-card-text"><%= project.short_description %></p>

            <div class="project-meta">
              <span>⏱ <%= project.estimated_duration.to_s.humanize %></span>
              <span>👥 <%= project.accepted_members_count %> / <%= project.max_collaborators %></span>
            </div>

            <div class="tech-list">
              <% if project.technologies.any? %>
                <% project.technologies.each do |technology| %>
                  <span class="tech-badge"><%= technology.name %></span>
                <% end %>
              <% else %>
                <span class="muted-text">No technologies yet</span>
              <% end %>
            </div>

            <div class="project-card-footer">
              <span class="muted-text">Owner</span>
              <div>
                <%= link_to "View", project_path(project), class: "btn btn-secondary" %>
                <%= link_to "Edit", edit_project_path(project), class: "btn btn-secondary" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <h3>No created projects yet</h3>
        <p>Start your first project and invite other developers to join.</p>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <h2>Projects I joined</h2>
      <p class="muted-text">Projects where your collaboration is accepted.</p>
    </div>

    <% if @joined_projects.any? %>
      <div class="projects-grid">
        <% @joined_projects.each do |project| %>
          <article class="project-card">
            <div class="project-card-top">
              <span class="badge"><%= project.status.capitalize %></span>
              <span class="badge badge-light"><%= project.category.to_s.humanize %></span>
            </div>

            <h3><%= link_to project.title, project_path(project), class: "project-card-title" %></h3>
            <p class="project-card-text"><%= project.short_description %></p>

            <div class="project-meta">
              <span>⏱ <%= project.estimated_duration.to_s.humanize %></span>
              <span>👥 <%= project.accepted_members_count %> / <%= project.max_collaborators %></span>
            </div>

            <div class="tech-list">
              <% if project.technologies.any? %>
                <% project.technologies.each do |technology| %>
                  <span class="tech-badge"><%= technology.name %></span>
                <% end %>
              <% else %>
                <span class="muted-text">No technologies yet</span>
              <% end %>
            </div>

            <div class="project-card-footer">
              <span class="muted-text">
                Owner: <strong><%= project.owner&.display_name || "Unknown" %></strong>
              </span>
              <%= link_to "View", project_path(project), class: "btn btn-secondary" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <h3>No joined projects yet</h3>
        <p>You have not joined any project yet.</p>
      </div>
    <% end %>
  </section>
</div>
