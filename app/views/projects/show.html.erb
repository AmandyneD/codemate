<div class="page-shell-modern">

  <p class="back-link-modern">
    <%= link_to "← Back to projects", projects_path %>
  </p>

  <!-- HERO -->
  <section class="project-hero-modern">

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

      <!-- Badges -->
      <div class="d-flex gap-2">
        <span class="badge-orange"><%= @project.status.capitalize %></span>
        <span class="badge-grey"><%= @project.category %></span>
      </div>

      <!-- Owner actions -->
      <% if user_signed_in? && @project.owner == current_user %>
        <div class="d-flex gap-2">
          <%= link_to "Edit project", edit_project_path(@project), class: "btn btn-primary" %>

          <%= button_to "Delete project",
                project_path(@project),
                method: :delete,
                form: { data: { turbo_confirm: "Are you sure you want to delete this project?" } },
                class: "btn btn-danger" %>
        </div>
      <% end %>

    </div>

  </section>

  <!-- LAYOUT -->
  <div class="project-layout">

    <!-- MAIN CONTENT -->
    <main class="content-card">

      <h1 class="project-title-modern honk mb-4"><%= @project.title %></h1>

      <!-- ABOUT -->
      <section class="content-section">
        <h5>About this project</h5>
        <p class="muted-text-modern"><%= @project.description %></p>
      </section>

      <!-- TECHNOLOGIES -->
      <section class="content-section">
        <h5>Technologies</h5>

        <div class="tech-list">
          <% if @project.technologies.any? %>
            <% @project.technologies.each do |technology| %>
              <span class="tech-badge-modern"><%= technology.name %></span>
            <% end %>
          <% else %>
            <span class="muted-text-modern">No technologies added yet</span>
          <% end %>
        </div>
      </section>

      <!-- TEAM MEMBERS -->
      <section class="content-section">
        <h5>Team members</h5>

        <% if @accepted_collaborations.any? %>
          <div class="member-list">

            <% @accepted_collaborations.each do |collaboration| %>
              <div class="member-card">

                <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">

                  <%= link_to user_path(collaboration.user),
                        class: "member-card-link flex-grow-1" do %>

                    <strong><%= collaboration.user.display_name %></strong>

                    <% if collaboration.owner %>
                      <span class="member-role">Owner</span>
                    <% elsif collaboration.role.present? %>
                      <span class="member-role"><%= collaboration.role %></span>
                    <% end %>

                  <% end %>

                  <% if @is_owner && !collaboration.owner %>
                    <%= button_to "Remove",
                          project_collaboration_path(@project, collaboration),
                          method: :patch,
                          params: { status: "removed" },
                          form: { data: { turbo_confirm: "Are you sure you want to remove this member?" } },
                          class: "btn btn-danger" %>
                  <% end %>

                </div>

              </div>
            <% end %>

          </div>

        <% else %>
          <p class="muted-text">No team members yet.</p>
        <% end %>

      </section>

    </main>

    <!-- SIDEBAR -->
    <aside class="sidebar-card">

      <h5>Project info</h5>

      <ul class="info-list">
        <li><strong>Owner:</strong> <%= @project_owner&.display_name || "Unknown" %></li>
        <li><strong>Duration:</strong> <%= @project.estimated_duration.humanize %></li>
        <li><strong>Team size:</strong> <%= @project.accepted_members_count %> / <%= @project.max_collaborators %></li>
        <li><strong>Status:</strong> <%= @project.status.capitalize %></li>
      </ul>

      <!-- FAVORITES -->
      <% if user_signed_in? %>
        <% if @existing_bookmark.present? %>
          <%= button_to "Remove from favorites",
                project_bookmark_path(@project, @existing_bookmark),
                method: :delete,
                class: "btn btn-secondary" %>
        <% else %>
          <%= button_to "Add to favorites",
                project_bookmarks_path(@project),
                method: :post,
                class: "btn btn-primary" %>
        <% end %>
      <% end %>

      <!-- JOIN LOGIC -->
      <% if user_signed_in? %>

        <% unless @is_owner %>

          <% if @existing_collaboration.nil? && @project.recruiting? %>
            <%= button_to "Join project",
                  project_collaborations_path(@project),
                  method: :post,
                  class: "btn btn-primary p-2" %>

          <% elsif @existing_collaboration&.status == "pending" %>
            <div class="callout">Your request is pending.</div>

          <% elsif @existing_collaboration&.status == "accepted" %>
            <div class="callout success">You are part of this project.</div>

          <% elsif @existing_collaboration&.status == "rejected" %>
            <div class="callout">Your request was rejected.</div>

          <% elsif !@project.recruiting? %>
            <div class="callout">This project is not currently recruiting.</div>
          <% end %>

        <% end %>

      <% else %>
        <div class="callout">
          <%= link_to "Log in", new_user_session_path %> to request to join this project.
        </div>
      <% end %>

      <!-- RECRUITING STATUS -->
      <% if @project.recruiting? %>
        <div class="callout success">This project is currently recruiting.</div>
      <% else %>
        <div class="callout">This project is not currently recruiting.</div>
      <% end %>

      <!-- PENDING REQUESTS -->
      <h5 class="h3 mt-4">Pending join requests</h5>

      <% if @pending_collaborations.any? %>

        <div class="member-list">

          <% @pending_collaborations.each do |collaboration| %>
            <div class="member-card">

              <div>
                <strong><%= collaboration.user.display_name %></strong>
                <div class="muted-text"><%= collaboration.user.email %></div>
              </div>

              <div class="d-flex gap-2 align-items-center flex-wrap">

                <%= form_with url: project_collaboration_path(@project, collaboration),
                              method: :patch,
                              local: true,
                              class: "d-flex gap-2 align-items-center flex-wrap" do %>

                  <%= hidden_field_tag :status, "accepted" %>

                  <%= select_tag :role,
                        options_for_select([
                          ["Frontend developer", "Frontend developer"],
                          ["Backend developer", "Backend developer"],
                          ["Full-stack developer", "Full-stack developer"],
                          ["Mobile developer", "Mobile developer"],
                          ["UI / UX Designer", "UI / UX Designer"],
                          ["Product manager", "Product manager"],
                          ["Data / AI", "Data / AI"],
                          ["DevOps", "DevOps"],
                          ["Other", "Other"]
                        ], collaboration.role),
                        class: "form-select" %>

                  <%= submit_tag "Accept", class: "btn btn-primary" %>

                <% end %>

                <%= button_to "Reject",
                      project_collaboration_path(@project, collaboration),
                      method: :patch,
                      params: { status: "rejected" },
                      class: "btn btn-secondary" %>

              </div>

            </div>
          <% end %>

        </div>

      <% else %>
        <p class="muted-text">No pending requests.</p>
      <% end %>

    </aside>

  </div>

</div>