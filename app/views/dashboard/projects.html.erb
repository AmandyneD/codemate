<div class="page-shell layout-container dashboard-page">
  <div class="page-header dashboard-header">
    <div>
      <h1 class="title-xl">My projects</h1>
      <p class="page-subtitle">Manage your drafts, published projects, and collaborations.</p>
    </div>

    <%= link_to "Create a project", new_project_path, class: "btn btn-primary dashboard-create-btn" %>
  </div>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2 class="title-lg">Projects I created</h2>
        <p class="muted-text">Includes drafts and published projects.</p>
      </div>
      <span class="section-count"><%= @owned_projects.count %></span>
    </div>

    <% if @owned_projects.any? %>
      <div class="dashboard-grid">
        <% @owned_projects.each do |project| %>
          <article class="dashboard-project-card">
            <div class="dashboard-project-top">
              <span class="badge-status badge-status--<%= project.display_status %>">
                <%= project.display_status.capitalize %>
              </span>
            </div>

            <h3 class="dashboard-project-title">
              <%= link_to project.title, project_path(project) %>
            </h3>

            <p class="dashboard-project-text"><%= project.short_description %></p>

            <div class="project-meta">
              <span class="project-meta-item">
                <%= image_tag "icon_cube_W.svg", class: "project-inline-icon", alt: "Category" %>
                <%= project.category.to_s.humanize %>
              </span>

              <span class="project-meta-item">
                <%= image_tag "icon_planning_W.svg", class: "project-inline-icon", alt: "Duration" %>
                <%= project.estimated_duration.to_s.humanize %>
              </span>

              <span class="project-meta-item">
                <%= image_tag "icon_user_W.svg", class: "project-inline-icon", alt: "Members" %>
                <%= project.accepted_members_count %> / <%= project.max_collaborators %>
              </span>
            </div>

            <div class="tech-list">
              <% if project.technologies.any? %>
                <% project.technologies.each do |technology| %>
                  <span class="tech-badge tech-badge--project"><%= technology.name %></span>
                <% end %>
              <% else %>
                <span class="muted-text">No technologies yet</span>
              <% end %>
            </div>

            <div class="dashboard-project-footer">
              <span class="muted-text">Owner</span>

              <div class="dashboard-project-actions">
                <%= link_to "View", project_path(project), class: "btn btn-secondary btn-sm" %>
                <%= link_to "Edit", edit_project_path(project), class: "btn btn-secondary btn-sm" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <h3 class="title-lg">No created projects yet</h3>
        <p class="page-subtitle">Start your first project and invite other developers to join.</p>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section">
    <div class="section-heading">
      <div>
        <h2 class="title-lg">Projects I joined</h2>
        <p class="muted-text">Projects where your collaboration is accepted.</p>
      </div>
      <span class="section-count"><%= @joined_projects.count %></span>
    </div>

    <% if @joined_projects.any? %>
      <div class="dashboard-grid">
        <% @joined_projects.each do |project| %>
          <article class="dashboard-project-card">
            <div class="dashboard-project-top">
              <span class="badge-status badge-status--<%= project.display_status %>">
                <%= project.display_status.capitalize %>
              </span>
            </div>

            <h3 class="dashboard-project-title">
              <%= link_to project.title, project_path(project) %>
            </h3>

            <p class="dashboard-project-text"><%= project.short_description %></p>

            <div class="project-meta">
              <span class="project-meta-item">
                <%= image_tag "icon_cube_W.svg", class: "project-inline-icon", alt: "Category" %>
                <%= project.category.to_s.humanize %>
              </span>

              <span class="project-meta-item">
                <%= image_tag "icon_planning_W.svg", class: "project-inline-icon", alt: "Duration" %>
                <%= project.estimated_duration.to_s.humanize %>
              </span>

              <span class="project-meta-item">
                <%= image_tag "icon_user_W.svg", class: "project-inline-icon", alt: "Members" %>
                <%= project.accepted_members_count %> / <%= project.max_collaborators %>
              </span>
            </div>

            <div class="tech-list">
              <% if project.technologies.any? %>
                <% project.technologies.each do |technology| %>
                  <span class="tech-badge tech-badge--project"><%= technology.name %></span>
                <% end %>
              <% else %>
                <span class="muted-text">No technologies yet</span>
              <% end %>
            </div>

            <div class="dashboard-project-footer">
              <span class="muted-text">Collaborator</span>

              <div class="dashboard-project-actions">
                <%= link_to "View", project_path(project), class: "btn btn-secondary btn-sm" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <h3 class="title-lg">No joined projects yet</h3>
        <p class="page-subtitle">You have not joined any projects yet.</p>
      </div>
    <% end %>
  </section>
</div>
