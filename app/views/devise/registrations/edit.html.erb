<div class="page-shell-centered">

  <p class="back-link">
    <%= link_to "← Back to profile", user_path(current_user) %>
  </p>

  <div class="page-header-centered">
    <h1 class="honk">Account settings</h1>
    <p class="page-subtitle-modern">Update your email address or password.</p>
  </div>

  <div class="content-card-centered">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <section class="content-section-centered">
        <h2 class="section-title">Account</h2>

        <div class="field mb-3">
          <%= f.label :email, "Email", class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="muted-text">
            Currently waiting confirmation for: <%= resource.unconfirmed_email %>
          </p>
        <% end %>

        <div class="field mb-3">
          <%= f.label :password, "New password", class: "form-label" %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "Leave blank if you don’t want to change it", class: "form-control" %>
        </div>

        <div class="field mb-3">
          <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>

        <div class="field mb-3">
          <%= f.label :current_password, "Current password", class: "form-label" %>
          <%= f.password_field :current_password, class: "form-control" %>
          <small class="muted-text">Required to confirm your changes.</small>
        </div>
      </section>

      <div class="actions mt-4">
        <%= f.submit "Save account settings", class: "btn btn-orange w-100" %>
      </div>

    <% end %>
  </div>

  <div class="content-card-centered mt-4 danger-card">
    <section class="content-section-centered">
      <h2 class="section-title text-danger">Danger zone</h2>
      <p class="muted-text">Delete your account permanently.</p>

      <%= button_to "Delete my account",
        registration_path(resource_name),
        data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
        method: :delete,
        class: "btn btn-danger w-100" %>
    </section>
  </div>

</div>

<style>
  :root {
    --navy: #0a0f1f;
    --navy-light: #11182e;
    --orange: #ff7a00;
    --grey-light: #d1d5db;
    --grey-mid: #9ca3af;
    --white: #ffffff;
    --red: #ff4d4d;
  }

  body {
    background: var(--navy);
    color: var(--white);
  }

  /* --- PAGE CENTRÉE --- */
  .page-shell-centered {
    max-width: 700px;
    margin: 0 auto;
    padding: 40px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-header-centered {
    text-align: center;
    margin-bottom: 32px;
  }

  .honk {
    font-family: "Honk", system-ui;
    font-variation-settings: "MORF" 15, "SHLN" 50;
  }

  .page-subtitle-modern {
    color: var(--grey-light);
  }

  .back-link a {
    color: var(--grey-light);
    text-decoration: none;
  }
  .back-link a:hover {
    color: var(--orange);
  }

  /* --- CARD PRINCIPALE --- */
  .content-card-centered {
    width: 100%;
    max-width: 600px;
    background: var(--navy-light);
    padding: 32px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 10px 30px rgba(0,0,0,0.25);
  }

  .danger-card {
    border-color: rgba(255, 77, 77, 0.4);
  }

  /* --- SECTIONS --- */
  .content-section-centered {
    margin-bottom: 32px;
  }

  .section-title {
    font-size: 22px;
    margin-bottom: 16px;
  }

  .text-danger {
    color: var(--red);
  }

  /* --- FORM FIELDS --- */
  .form-label {
    color: var(--grey-light);
    font-weight: 600;
  }

  .form-control {
    background: #0d1326;
    border: 1px solid var(--grey-mid);
    color: var(--white);
    border-radius: 10px;
    padding: 12px;
  }

  .form-control:focus {
    border-color: var(--orange);
    box-shadow: 0 0 0 0.25rem rgba(255, 122, 0, 0.35);
  }

  .muted-text {
    color: var(--grey-light);
    font-size: 14px;
  }

  /* --- BUTTONS --- */
  .btn-orange {
    background: var(--orange);
    color: var(--navy);
    font-weight: 700;
    padding: 12px;
    border-radius: 10px;
    border: none;
  }
  .btn-orange:hover {
    background: #ff8f26;
  }

  .btn-danger {
    background: var(--red);
    color: var(--white);
    font-weight: 700;
    padding: 12px;
    border-radius: 10px;
    border: none;
  }
  .btn-danger:hover {
    background: #ff6666;
  }
</style>