<nav class="navbar navbar-expand-lg topbar-modern sticky-top">
  <div class="navbar-container">
    <%= link_to root_path, class: "navbar-brand codemate-brand" do %>
      <%= image_tag "mate_blanc.svg", height: 40, class: "brand-icon", alt: "Logo" %>
      <%= image_tag "codemate_blanc.svg", height: 22, class: "brand-wordmark", alt: "Codemate" %>
    <% end %>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarPremium"
      aria-controls="navbarPremium"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarPremium">
      <ul class="navbar-nav navbar-links">
        <li class="nav-item">
          <%= link_to "Explore projects",
            projects_path,
            class: "nav-link custom-nav-link #{'is-active' if current_page?(projects_path)}" %>
        </li>

        <li class="nav-item">
          <%= link_to "Browse builders",
            users_path,
            class: "nav-link custom-nav-link nav-link-builders #{'is-active' if current_page?(users_path)}" %>
        </li>

        <% if user_signed_in? %>
          <li class="nav-item">
            <%= link_to "My projects",
              my_projects_path,
              class: "nav-link custom-nav-link #{'is-active' if current_page?(my_projects_path)}" %>
          </li>
        <% end %>
      </ul>

      <div class="navbar-right">
        <% if user_signed_in? %>
        <%= link_to new_project_path, class: "navbar-cta glitch-btn js-navbar-glitch", data: { text: "Create project" } do %>
          <span class="glitch-btn__text" data-text="Create project">Create project</span>
          <span class="glitch-btn__noise" aria-hidden="true"></span>
          <span class="glitch-btn__scanline" aria-hidden="true"></span>
        <% end %>

          <details class="user-dropdown">
            <summary class="user-menu-button">
              <% if current_user.avatar.attached? %>
                <%= image_tag current_user.avatar, class: "navbar-avatar", alt: current_user.display_name %>
              <% else %>
                <div class="navbar-avatar-fallback">
                  <%= current_user.display_name.to_s.first.upcase %>
                </div>
              <% end %>

              <span class="navbar-username"><%= current_user.display_name %></span>
              <span class="navbar-caret">▾</span>
            </summary>

            <div class="user-dropdown-menu">
              <%= link_to "Profile", user_path(current_user), class: "dropdown-item" %>
              <%= link_to "Edit profile", edit_user_path(current_user), class: "dropdown-item" %>
              <%= link_to "My projects", my_projects_path, class: "dropdown-item" %>
              <%= link_to "Favorites", my_favorites_path, class: "dropdown-item" %>
              <%= link_to "Inbox", conversations_path, class: "dropdown-item" %>
              <%= link_to "Account settings", edit_user_registration_path, class: "dropdown-item" %>

              <div class="user-dropdown-divider"></div>

              <%= button_to "Logout",
                destroy_user_session_path,
                method: :delete,
                class: "dropdown-item logout-button" %>
            </div>
          </details>
        <% else %>
          <div class="navbar-auth-actions">
            <%= link_to "Sign up", new_user_registration_path, class: "nav-link custom-nav-link" %>
            <%= link_to "Log in", new_user_session_path, class: "navbar-cta" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</nav>
