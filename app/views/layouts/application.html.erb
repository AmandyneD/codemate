<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Codemate" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jersey+10&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Jersey+10&display=swap" rel="stylesheet">

    <style>
      .topbar {
        padding: 14px 24px;
        border-bottom: 1px solid #e5e7eb;
        margin-bottom: 24px;
        background: white;
      }

      .topbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .topbar-left,
      .topbar-right {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .brand-link {
        font-weight: 700;
        text-decoration: none;
        color: inherit;
      }

      .nav-link {
        text-decoration: none;
        color: inherit;
      }


      .flash {
        max-width: 1100px;
        margin: 0 auto 16px;
        padding: 12px 16px;
        border-radius: 12px;
      }

      .flash-notice {
        background: #eef6ff;
        color: #1d4ed8;
      }

      .flash-alert {
        background: #fef2f2;
        color: #b91c1c;
      }
    </style>

  </head>

  <body>

    <%= render "partials/navbar" %>

    <%= yield %>
  </body>
</html>
