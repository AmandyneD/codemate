<div class="conversation-layout">

  <div class="conversation-thread-card card">

    <div class="conversation-thread-header">
      <h2 class="title-lg">Messages</h2>
      <span class="badge-count"><%= @messages.count %></span>
    </div>

    <div class="conversation-thread-body">

      <% if @messages.any? %>
        <div class="conversation-message-list">
          <% @messages.each do |message| %>

            <% mine = message.user == current_user %>

            <div class="conversation-message <%= mine ? "conversation-message--mine" : "conversation-message--other" %>">

              <div class="conversation-message-meta">
                <strong><%= message.user.display_name %></strong>
                <small class="muted-text">
                  <%= l(message.created_at, format: :short) %>
                </small>
              </div>

              <div class="conversation-message-bubble">
                <p><%= message.content %></p>
              </div>

            </div>

          <% end %>
        </div>
      <% else %>
        <div class="conversation-empty-state card">
          <h3 class="title-md">No messages yet</h3>
          <p class="muted-text">Start the conversation.</p>
        </div>
      <% end %>

    </div>

    <!-- ✅ FORM NOW HERE -->
    <div class="conversation-form-section">

      <%= form_with model: [@conversation, @message], local: true, class: "conversation-form" do |f| %>

        <%= f.label :content, "New message" %>

        <%= f.text_area :content,
          class: "conversation-textarea",
          placeholder: "Write your message…" %>

        <div class="conversation-form-actions">
          <%= f.submit "Send", class: "btn btn-primary conversation-send-btn" %>
        </div>

      <% end %>

    </div>

  </div>

  <!-- Sidebar stays project info only -->
  <div class="conversation-sidebar-card card">
    <h2 class="title-lg">Project</h2>

    <ul class="conversation-info-list">
      <li>Title: <%= @project.title %></li>
      <li>Owner: <%= @project.owner.display_name %></li>
      <li>Status: <%= @project.status.capitalize %></li>
      <li>Team: <%= @project.accepted_members_count %> / <%= @project.max_collaborators %></li>
    </ul>
  </div>

</div>
