<div class="page-shell layout-container profile-page profile-page--enhanced">
  <p class="back-link profile-back-link">
    <%= link_to "← Back", request.referer.presence || projects_path %>
  </p>

  <section class="profile-hero">
    <div class="profile-hero-inner">

      <div class="profile-hero-left">
        <div class="profile-avatar-wrap">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar, class: "profile-avatar-xl" %>
          <% else %>
            <div class="profile-avatar-fallback-xl">
              <%= @user.display_name.first.upcase %>
            </div>
          <% end %>
        </div>

        <div class="profile-hero-text">
          <h1 class="profile-hero-name">
            <%= @user.display_name %>
          </h1>

          <p class="profile-hero-bio">
            <%= @user.bio.presence || "This member has not added a bio yet." %>
          </p>

          <div class="profile-hero-meta">
            <% if @user.github_url.present? %>
              <span class="profile-chip">
                GitHub
                <%= link_to @user.github_url.sub(%r{https?://}, ""), @user.github_url, target: "_blank" %>
              </span>
            <% end %>
          </div>
        </div>
      </div>

      <% if current_user == @user %>
        <div class="profile-hero-actions">
          <%= link_to "Edit profile", edit_user_path(@user), class: "btn btn-profile btn-md" %>
        </div>
      <% end %>

    </div>
  </section>

  <section class="profile-stats-strip">
    <article class="profile-stat-card">
      <span class="profile-stat-label">Created projects</span>
      <strong class="profile-stat-number"><%= @owned_projects.count %></strong>
    </article>

    <article class="profile-stat-card">
      <span class="profile-stat-label">Joined projects</span>
      <strong class="profile-stat-number"><%= @joined_projects.count %></strong>
    </article>

    <article class="profile-stat-card">
      <span class="profile-stat-label">Favorites</span>
      <strong class="profile-stat-number"><%= @favorite_projects.count %></strong>
    </article>
  </section>

  <div class="profile-layout profile-layout--enhanced">
    <main class="content-card profile-main-card">
      <section class="content-section profile-section">
        <div class="section-heading profile-section-heading">
          <div>
            <p class="profile-section-kicker">Stack</p>
            <h2 class="title-lg">Technologies</h2>
          </div>
        </div>

        <div class="tech-list profile-tech-list">
          <% if @user.technologies.any? %>
            <% @user.technologies.order(:name).each do |technology| %>
              <span class="tech-badge profile-tech-badge profile-tech-badge--blue"><%= technology.name %></span>
            <% end %>
          <% else %>
            <span class="muted-text">No technologies added yet.</span>
          <% end %>
        </div>
      </section>

      <section class="content-section profile-section">
        <div class="section-heading profile-section-heading">
          <div>
            <p class="profile-section-kicker">Portfolio</p>
            <h2 class="title-lg">Created projects</h2>
          </div>
          <span class="section-count"><%= @owned_projects.count %></span>
        </div>

        <% if @owned_projects.any? %>
          <div class="dashboard-grid">
            <% @owned_projects.each do |project| %>
              <article class="dashboard-project-card profile-project-card">
                <div class="dashboard-project-top">
                  <span class="badge-status badge-status--<%= project.display_status %>">
                    <%= project.display_status.capitalize %>
                  </span>
                </div>

                <h3 class="dashboard-project-title">
                  <%= link_to project.title, project_path(project) %>
                </h3>

                <p class="dashboard-project-text">
                  <%= project.short_description.presence || "No description yet." %>
                </p>

                <div class="project-meta">
                  <span class="project-meta-item">
                    <%= image_tag "icon_cube_W.svg", class: "project-inline-icon", alt: "Category" %>
                    <%= project.category.to_s.humanize %>
                  </span>

                  <span class="project-meta-item">
                    <%= image_tag "icon_planning_W.svg", class: "project-inline-icon", alt: "Duration" %>
                    <%= project.estimated_duration.to_s.humanize %>
                  </span>

                  <span class="project-meta-item">
                    <%= image_tag "icon_user_W.svg", class: "project-inline-icon", alt: "Members" %>
                    <%= project.accepted_members_count %> / <%= project.max_collaborators %>
                  </span>
                </div>

                <div class="tech-list">
                  <% if project.technologies.any? %>
                    <% project.technologies.each do |technology| %>
                      <span class="tech-badge tech-badge--project"><%= technology.name %></span>
                    <% end %>
                  <% else %>
                    <span class="muted-text">No technologies yet</span>
                  <% end %>
                </div>

                <div class="dashboard-project-footer">
                  <span class="project-card-owner">
                    Owner: <strong><%= project.owner&.display_name || "Unknown" %></strong>
                  </span>

                  <div class="dashboard-project-actions">
                    <%= link_to "View", project_path(project), class: "btn btn-secondary btn-sm" %>
                  </div>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="muted-text">No created projects yet.</p>
        <% end %>
      </section>

      <section class="content-section profile-section">
        <div class="section-heading profile-section-heading">
          <div>
            <p class="profile-section-kicker">Collaboration</p>
            <h2 class="title-lg">Joined projects</h2>
          </div>
          <span class="section-count"><%= @joined_projects.count %></span>
        </div>

        <% if @joined_projects.any? %>
          <div class="dashboard-grid">
            <% @joined_projects.each do |project| %>
              <article class="dashboard-project-card profile-project-card">
                <div class="dashboard-project-top">
                  <span class="badge-status badge-status--<%= project.display_status %>">
                    <%= project.display_status.capitalize %>
                  </span>
                </div>

                <h3 class="dashboard-project-title">
                  <%= link_to project.title, project_path(project) %>
                </h3>

                <p class="dashboard-project-text">
                  <%= project.short_description.presence || "No description yet." %>
                </p>

                <div class="project-meta">
                  <span class="project-meta-item">
                    <%= image_tag "icon_cube_W.svg", class: "project-inline-icon", alt: "Category" %>
                    <%= project.category.to_s.humanize %>
                  </span>

                  <span class="project-meta-item">
                    <%= image_tag "icon_planning_W.svg", class: "project-inline-icon", alt: "Duration" %>
                    <%= project.estimated_duration.to_s.humanize %>
                  </span>

                  <span class="project-meta-item">
                    <%= image_tag "icon_user_W.svg", class: "project-inline-icon", alt: "Members" %>
                    <%= project.accepted_members_count %> / <%= project.max_collaborators %>
                  </span>
                </div>

                <div class="tech-list">
                  <% if project.technologies.any? %>
                    <% project.technologies.each do |technology| %>
                      <span class="tech-badge tech-badge--project"><%= technology.name %></span>
                    <% end %>
                  <% else %>
                    <span class="muted-text">No technologies yet</span>
                  <% end %>
                </div>

                <div class="dashboard-project-footer">
                  <span class="project-card-owner">
                    Owner: <strong><%= project.owner&.display_name || "Unknown" %></strong>
                  </span>

                  <div class="dashboard-project-actions">
                    <%= link_to "View", project_path(project), class: "btn btn-secondary btn-sm" %>
                  </div>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="muted-text">No joined projects yet.</p>
        <% end %>
      </section>
    </main>

    <aside class="sidebar-card profile-sidebar-card">
      <section class="content-section profile-section">
        <div class="section-heading profile-section-heading">
          <div>
            <p class="profile-section-kicker">Saved</p>
            <h2 class="title-lg">Favorite projects</h2>
          </div>
          <span class="section-count"><%= @favorite_projects.count %></span>
        </div>

        <% if @favorite_projects.any? %>
          <div class="section-stack">
            <% @favorite_projects.each do |project| %>
              <article class="dashboard-project-card profile-project-card">
                <div class="dashboard-project-top">
                  <span class="badge-status badge-status--<%= project.display_status %>">
                    <%= project.display_status.capitalize %>
                  </span>
                </div>

                <h3 class="dashboard-project-title">
                  <%= link_to project.title, project_path(project) %>
                </h3>

                <p class="dashboard-project-text">
                  <%= project.short_description.presence || "No description yet." %>
                </p>

                <div class="project-meta">
                  <span class="project-meta-item">
                    <%= image_tag "icon_cube_W.svg", class: "project-inline-icon", alt: "Category" %>
                    <%= project.category.to_s.humanize %>
                  </span>

                  <span class="project-meta-item">
                    <%= image_tag "icon_planning_W.svg", class: "project-inline-icon", alt: "Duration" %>
                    <%= project.estimated_duration.to_s.humanize %>
                  </span>

                  <span class="project-meta-item">
                    <%= image_tag "icon_user_W.svg", class: "project-inline-icon", alt: "Members" %>
                    <%= project.accepted_members_count %> / <%= project.max_collaborators %>
                  </span>
                </div>

                <div class="tech-list">
                  <% if project.technologies.any? %>
                    <% project.technologies.each do |technology| %>
                      <span class="tech-badge tech-badge--project"><%= technology.name %></span>
                    <% end %>
                  <% else %>
                    <span class="muted-text">No technologies yet</span>
                  <% end %>
                </div>

                <div class="dashboard-project-footer">
                  <span class="project-card-owner">
                    Owner: <strong><%= project.owner&.display_name || "Unknown" %></strong>
                  </span>

                  <div class="dashboard-project-actions">
                    <%= link_to "View", project_path(project), class: "btn btn-secondary btn-sm" %>
                  </div>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <p class="muted-text">No favorite projects yet.</p>
        <% end %>
      </section>
    </aside>
  </div>
</div>
