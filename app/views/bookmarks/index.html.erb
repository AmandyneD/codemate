<div class="page-shell favorites-page">
  <div class="page-header">
    <div>
      <h1 class="title-xl">My favorite projects</h1>
      <p class="page-subtitle">Projects you saved to revisit later.</p>
    </div>
  </div>

  <div class="content-card favorites-card">
    <% if @favorite_projects.any? %>
      <div class="project-list project-list-clean">
        <% @favorite_projects.each do |project| %>
          <%= link_to project_path(project), class: "project-row-card project-row-card-clean" do %>
            <div class="project-row-card-content project-row-card-content-clean">
              <div class="project-row-card-main project-row-card-main-clean">
                <h3 class="project-row-title"><%= project.title %></h3>
                <p class="project-row-description">
                  <%= project.short_description.presence || "No description yet." %>
                </p>

                <div class="project-row-tags">
                  <span class="project-row-meta-item"><%= project.category.to_s.humanize %></span>
                  <span class="project-row-meta-item"><%= project.estimated_duration.to_s.humanize %></span>
                </div>
              </div>

              <div class="project-row-card-meta project-row-card-meta-clean">
                <span class="badge-status"><%= project.status.capitalize %></span>
                <span class="project-row-open">View</span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <h2 class="title-lg">No favorite projects yet</h2>
        <p class="page-subtitle">Save projects to find them quickly later.</p>
      </div>
    <% end %>
  </div>
</div>
