<div class="page-shell profile-edit-page profile-edit-page--enhanced">
  <p class="back-link profile-back-link">
    <%= link_to "← Back to profile", user_path(@user) %>
  </p>

  <section class="profile-edit-hero-shell">
    <div class="profile-hero-glow profile-hero-glow--green"></div>
    <div class="profile-hero-glow profile-hero-glow--plum"></div>

    <section class="profile-hero-card profile-edit-hero-card">
      <div class="profile-hero-main">
        <div class="profile-avatar-wrap profile-avatar-wrap--enhanced">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar, class: "profile-avatar-large profile-avatar-large--enhanced", alt: @user.display_name %>
          <% else %>
            <div class="profile-avatar-fallback profile-avatar-fallback--enhanced">
              <%= @user.display_name.to_s.first.upcase %>
            </div>
          <% end %>
        </div>

        <div class="profile-hero-content">
          <span class="profile-eyebrow">Edit builder profile</span>
          <h1 class="title-xl profile-edit-title">Edit profile</h1>
          <p class="page-subtitle profile-edit-subtitle">
            Update your public profile, stack and avatar so other builders can understand who you are.
          </p>

          <div class="profile-meta profile-meta--enhanced">
            <span class="profile-meta-item profile-meta-item--enhanced">
              <strong><%= @user.technology_ids.count %></strong>
              technologies
            </span>

            <span class="profile-meta-item profile-meta-item--enhanced">
              <strong><%= @user.avatar.attached? ? "1" : "0" %></strong>
              avatar
            </span>

            <span class="profile-meta-item profile-meta-item--enhanced">
              <strong><%= @user.github_url.present? ? "GitHub" : "Optional" %></strong>
              profile link
            </span>
          </div>
        </div>
      </div>
    </section>
  </section>

  <section class="profile-edit-form-card">
    <%= form_with model: @user, html: { multipart: true, class: "profile-edit-form" } do |f| %>

      <% if @user.errors.any? %>
        <div class="form-errors">
          <h2 class="title-md"><%= pluralize(@user.errors.count, "error") %> prevented this profile from being saved:</h2>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <section class="profile-edit-section">
        <div class="profile-section-heading">
          <div>
            <p class="profile-section-kicker">Public profile</p>
            <h2 class="title-lg">Identity</h2>
          </div>
        </div>

        <div class="field">
          <%= f.label :display_name, "Display name" %>
          <%= f.text_field :display_name, class: "auth-input" %>
        </div>

        <div class="field">
          <%= f.label :bio, "Bio" %>
          <%= f.text_area :bio, rows: 5, class: "auth-input", placeholder: "Tell other members a bit about yourself, your background, or what you like to build." %>
        </div>

        <div class="field">
          <%= f.label :github_url, "GitHub URL" %>
          <%= f.text_field :github_url, class: "auth-input", placeholder: "https://github.com/yourname" %>
        </div>
      </section>

      <section class="profile-edit-section profile-edit-section--stack">
        <div class="profile-section-heading">
          <div>
            <p class="profile-section-kicker">Builder stack</p>
            <h2 class="title-lg">Technologies</h2>
          </div>
        </div>

        <p class="muted-text profile-edit-helper">
          Select the technologies you use so other members can better understand your stack.
        </p>

        <%= hidden_field_tag "user[technology_ids][]", "" %>
        <%= render "technology_picker", user: @user %>
      </section>

      <section class="profile-edit-section profile-edit-section--avatar">
        <div class="profile-section-heading">
          <div>
            <p class="profile-section-kicker">Visual identity</p>
            <h2 class="title-lg">Avatar</h2>
          </div>
        </div>

        <div class="profile-avatar-upload-row">
          <div class="profile-avatar-upload-preview">
            <% if @user.avatar.attached? %>
              <%= image_tag @user.avatar, class: "profile-avatar-large profile-avatar-large--enhanced", alt: @user.display_name %>
            <% else %>
              <div class="profile-avatar-fallback profile-avatar-fallback--enhanced">
                <%= @user.display_name.to_s.first.upcase %>
              </div>
            <% end %>
          </div>

          <div class="profile-avatar-upload-fields">
            <p class="muted-text profile-edit-helper">
              Upload a clear image to make your profile more recognizable.
            </p>

            <div class="field">
              <%= f.label :avatar, "Upload avatar" %>
              <%= f.file_field :avatar, accept: "image/*" %>
            </div>
          </div>
        </div>
      </section>

      <div class="profile-edit-actions">
        <%= f.submit "Save profile", class: "btn btn-primary profile-edit-submit" %>
      </div>

    <% end %>
  </section>
</div>
