<div class="page-shell">
  <div class="page-header">
    <div>
      <h1 class="title-xl">Browse projects</h1>
      <p class="page-subtitle">
        Search by project name, technologies, and refine with advanced filters.
      </p>
    </div>

    <p class="muted-text">
      <strong><%= @projects.size %></strong> projects found
    </p>
  </div>

  <%= render "filters" %>

  <% if @projects.any? %>
    <div class="projects-grid projects-grid--premium">
      <% @projects.each do |project| %>
        <article class="project-card project-card--premium">
          <div class="project-card-top">
            <span class="badge-status"><%= project.status.capitalize %></span>
            <span class="badge-category"><%= project.category.humanize %></span>
          </div>

          <h2 class="project-card-title title-lg">
            <%= link_to project.title, project_path(project) %>
          </h2>

          <p class="project-card-description">
            <%= project.short_description %>
          </p>

          <div class="project-card-meta">
            <span class="project-meta-item">
              <%= image_tag "icon_planning_W.svg", class: "project-inline-icon", alt: "Duration" %>
              <%= project.estimated_duration.humanize %>
            </span>

            <span class="project-meta-item">
              <%= image_tag "icon_user_W.svg", class: "project-inline-icon", alt: "Members" %>
              <%= project.accepted_members_count %> / <%= project.max_collaborators %>
            </span>
          </div>

          <div class="project-card-technologies tech-list">
            <% if project.technologies.any? %>
              <% project.technologies.each do |tech| %>
                <span class="tech-badge"><%= tech.name %></span>
              <% end %>
            <% else %>
              <span class="muted-text">No technologies yet</span>
            <% end %>
          </div>

          <div class="project-card-footer">
            <span class="muted-text">
              Owner:
              <strong><%= project.owner&.display_name || "Unknown" %></strong>
            </span>

            <%= link_to "View project", project_path(project), class: "btn btn-outline project-card-cta" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <h2 class="title-lg">No open projects found</h2>
      <p class="page-subtitle">Try another search or remove some filters.</p>

      <%= link_to "Reset filters", projects_path, class: "btn btn-orange mt-3" %>
    </div>
  <% end %>
</div>
