<div class="page-shell-centered">

  <p class="back-link honk">
    <%= link_to "← Back", request.referer.presence || projects_path %>
  </p>

  <section class="profile-hero-card-centered">
    <div class="profile-hero-main">
      <div class="profile-avatar-wrap">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "profile-avatar profile-avatar-large" %>
        <% else %>
          <div class="profile-avatar-fallback">
            <%= @user.display_name.to_s.first.upcase %>
          </div>
        <% end %>
      </div>

      <div class="profile-hero-content">
        <h1 class="honk"><%= @user.display_name %></h1>

        <p class="page-subtitle-modern">
          <%= @user.bio.presence || "This member has not added a bio yet." %>
        </p>

        <div class="profile-meta">
          <% if @user.github_url.present? %>
            <span>
              <strong>GitHub:</strong>
              <%= link_to @user.github_url, @user.github_url, target: "_blank", rel: "noopener" %>
            </span>
          <% end %>

          <span><strong><%= @owned_projects.count %></strong> created</span>
          <span><strong><%= @joined_projects.count %></strong> joined</span>
        </div>
      </div>
    </div>

    <% if user_signed_in? && current_user == @user %>
      <div class="profile-hero-actions">
        <%= link_to "Edit profile", edit_user_path(@user), class: "btn btn-orange" %>
      </div>
    <% end %>
  </section>

  <main class="content-card-centered">

    <section class="content-section-centered">
      <div class="section-heading-centered">
        <h2>Technologies</h2>
      </div>

      <div class="tech-list-centered">
        <% if @user.technologies.any? %>
          <% @user.technologies.order(:name).each do |technology| %>
            <span class="tech-badge-centered"><%= technology.name %></span>
          <% end %>
        <% else %>
          <span class="muted-text">No technologies added yet.</span>
        <% end %>
      </div>
    </section>

    <section class="content-section-centered">
      <div class="section-heading-centered">
        <h2>Created projects</h2>
        <span class="section-count-centered"><%= @owned_projects.count %></span>
      </div>

      <% if @owned_projects.any? %>
        <div class="project-list-centered">
          <% @owned_projects.each do |project| %>
            <%= link_to project_path(project), class: "project-row-card-centered" do %>
              <div class="project-row-card-content">
                <div class="project-row-card-main">
                  <strong><%= project.title %></strong>
                  <div class="muted-text"><%= project.short_description %></div>
                </div>

                <div class="project-row-card-meta">
                  <span class="badge-centered"><%= project.status.capitalize %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="muted-text">No created projects yet.</p>
      <% end %>
    </section>

    <section class="content-section-centered">
      <div class="section-heading-centered">
        <h2>Joined projects</h2>
        <span class="section-count-centered"><%= @joined_projects.count %></span>
      </div>

      <% if @joined_projects.any? %>
        <div class="project-list-centered">
          <% @joined_projects.each do |project| %>
            <%= link_to project_path(project), class: "project-row-card-centered" do %>
              <div class="project-row-card-content">
                <div class="project-row-card-main">
                  <strong><%= project.title %></strong>
                  <div class="muted-text"><%= project.short_description %></div>
                </div>

                <div class="project-row-card-meta">
                  <span class="badge-centered"><%= project.status.capitalize %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="muted-text">No joined projects yet.</p>
      <% end %>
    </section>

    <section class="content-section-centered">
      <div class="section-heading-centered">
        <h2>Favorite projects</h2>
        <span class="section-count-centered"><%= @favorite_projects.count %></span>
      </div>

      <% if @favorite_projects.any? %>
        <div class="project-list-centered">
          <% @favorite_projects.each do |project| %>
            <%= link_to project_path(project), class: "project-row-card-centered" do %>
              <div class="project-row-card-content">
                <div class="project-row-card-main">
                  <strong><%= project.title %></strong>
                  <div class="muted-text"><%= project.short_description %></div>
                </div>

                <div class="project-row-card-meta">
                  <span class="badge-centered"><%= project.status.capitalize %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="muted-text">No favorite projects yet.</p>
      <% end %>
    </section>

  </main>
</div>

<style>
  :root {
    --navy: #0a0f1f;
    --navy-light: #11182e;
    --orange: #ff7a00;
    --grey-light: #d1d5db;
    --grey-mid: #9ca3af;
    --grey-dark: #4b5563;
    --white: #ffffff;
  }

  body {
    background: var(--navy);
    color: var(--white);
  }

  /* --- PAGE CENTRÉE --- */
  .page-shell-centered {
    max-width: 700px;
    margin: 0 auto;
    padding: 40px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .profile-hero-card-centered {
    width: 100%;
    max-width: 600px;
    background: var(--navy-light);
    padding: 32px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 32px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .content-card-centered {
    width: 100%;
    max-width: 600px;
    background: var(--navy-light);
    padding: 32px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 10px 30px rgba(0,0,0,0.25);
  }

  .content-section-centered {
    margin-bottom: 32px;
  }

  .section-heading-centered {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .section-count-centered {
    background: var(--orange);
    color: var(--navy);
    padding: 4px 10px;
    border-radius: 8px;
    font-weight: 700;
  }

  .tech-badge-centered {
    background: #0d1326;
    padding: 6px 12px;
    border-radius: 10px;
    border: 1px solid var(--grey-mid);
    margin-right: 6px;
    margin-bottom: 6px;
    display: inline-block;
  }

  .project-row-card-centered {
    display: block;
    background: #0d1326;
    padding: 16px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 12px;
    transition: 0.2s;
  }

  .project-row-card-centered:hover {
    border-color: var(--orange);
    background: rgba(255,122,0,0.05);
  }

  .badge-centered {
    background: var(--orange);
    color: var(--navy);
    padding: 4px 10px;
    border-radius: 8px;
    font-weight: 700;
  }

  .honk {
    font-family: "Honk", system-ui;
    font-variation-settings: "MORF" 15, "SHLN" 50;
  }

  .back-link a {
    color: var(--grey-light);
    text-decoration: none;
  }
  .back-link a:hover {
    color: var(--orange);
  }

  .profile-avatar-large {
    width: 110px;
    height: 110px;
    border-radius: 16px;
    object-fit: cover;
  }

  .profile-avatar-fallback {
    width: 110px;
    height: 110px;
    border-radius: 16px;
    background: var(--orange);
    color: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px;
    font-weight: 700;
  }

  .profile-meta span {
    margin-right: 16px;
    color: var(--grey-light);
  }

  .btn-orange {
    background: var(--orange);
    color: var(--navy);
    padding: 12px 20px;
    border-radius: 10px;
    font-weight: 700;
    border: none;
  }
  .btn-orange:hover {
    background: #ff8f26;
  }
</style>