<div class="project-form-shell">
  <div class="project-form-card">
    <%= form_with model: project do |f| %>
      <% if project.errors.any? %>
        <div class="form-errors">
          <h2 class="title-md"><%= pluralize(project.errors.count, "error") %> prevented this project from being saved:</h2>
          <ul>
            <% project.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="field">
        <%= f.label :title %>
        <%= f.text_field :title, placeholder: "Ex: Codemate, Airbnb clone, habit tracker..." %>
      </div>

      <div class="field">
        <%= f.label :short_description %>
        <%= f.text_field :short_description, placeholder: "A short summary for project cards" %>
      </div>

      <div class="field">
        <%= f.label :description %>
        <%= f.text_area :description, rows: 6, placeholder: "Describe the project, goals, and what kind of collaborators you are looking for." %>
      </div>

      <div class="project-form-grid">
        <div class="field">
          <%= f.label :category %>
          <%= f.select :category,
            [["Web app", "web_app"], ["Mobile app", "mobile_app"], ["SaaS", "saas"], ["AI", "ai"], ["Game", "game"], ["Tool", "tool"], ["Other", "other"]] %>
        </div>

        <div class="field">
          <%= f.label :estimated_duration %>
          <%= f.select :estimated_duration,
            [["Weekend", "weekend"], ["One week", "one_week"], ["Two weeks", "two_weeks"], ["One month", "one_month"], ["Three months", "three_months"], ["Long term", "long_term"]] %>
        </div>

        <div class="field">
          <%= f.label :max_collaborators %>
          <%= f.number_field :max_collaborators, min: 1, placeholder: "Ex: 4" %>
        </div>

        <div class="field">
          <%= f.label :status %>
          <%= f.select :status,
            [["Draft", "draft"], ["Open", "open"], ["Full", "full"], ["Closed", "closed"], ["Completed", "completed"]] %>
        </div>
      </div>

      <%= render "filters_new", project: project %>

      <div class="project-form-actions">
        <%= f.submit(
          project.persisted? ? "Save changes" : "Create project",
          class: "navbar-cta project-form-submit"
        ) %>
      </div>
    <% end %>
  </div>
</div>
