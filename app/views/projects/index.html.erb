<div class="page-shell layout-container">

  <div class="page-intro">
    <h1 class="title-xl">Explore projects</h1>
    <p class="page-subtitle">
      Search by project name, technologies, and refine with advanced filters.
    </p>

    <p class="muted-text page-intro-meta">
      <strong><%= @projects.size %></strong> projects found
    </p>
  </div>

  <div class="page-filters">
    <%= render "filters" %>
  </div>

  <% if @projects.any? %>
    <div class="projects-grid projects-grid--premium">
      <% @projects.each do |project| %>
        <article class="dashboard-project-card browse-project-card">
          <div class="dashboard-project-top">
            <span class="badge-status"><%= project.status.capitalize %></span>
            <span class="badge-category"><%= project.category.to_s.humanize %></span>
          </div>

          <h3 class="dashboard-project-title">
            <%= link_to project.title, project_path(project) %>
          </h3>

          <p class="dashboard-project-text"><%= project.short_description %></p>

          <div class="project-meta">
            <span class="project-meta-item">
              <%= image_tag "icon_planning_W.svg", class: "project-inline-icon", alt: "Duration" %>
              <%= project.estimated_duration.to_s.humanize %>
            </span>

            <span class="project-meta-item">
              <%= image_tag "icon_user_W.svg", class: "project-inline-icon", alt: "Members" %>
              <%= project.accepted_members_count %> / <%= project.max_collaborators %>
            </span>
          </div>

          <div class="tech-list">
            <% if project.technologies.any? %>
              <% project.technologies.each do |technology| %>
                <span class="tech-badge"><%= technology.name %></span>
              <% end %>
            <% else %>
              <span class="muted-text">No technologies yet</span>
            <% end %>
          </div>

          <div class="dashboard-project-footer">
            <span class="project-card-owner">
              Owner: <strong><%= project.owner&.display_name || "Unknown" %></strong>
            </span>

            <div class="dashboard-project-actions">
              <%= link_to "View", project_path(project), class: "btn btn-secondary btn-sm" %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <h2 class="title-lg">No open projects found</h2>
      <p class="page-subtitle">Try another search or remove some filters.</p>

      <%= link_to "Reset filters", projects_path, class: "btn btn-secondary btn-md mt-3" %>
    </div>
  <% end %>

</div>
