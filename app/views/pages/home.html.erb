<div class="home-shell">
  <section class="home-hero">
    <div class="home-hero-content">
      <h1 class="home-title honk">
        Build real projects.<br>
        Find your dev team.<br>
        Ship faster.
      </h1>

      <p class="home-subtitle">
        Join real projects, collaborate with other builders, and create work you can actually showcase.
      </p>

      <div class="home-cta">
        <% if user_signed_in? %>
          <%= link_to "Start a project", new_project_path, class: "btn-home-primary" %>
        <% else %>
          <%= link_to "Get started", new_user_registration_path, class: "btn-home-primary" %>
        <% end %>

        <%= link_to "Browse projects", projects_path, class: "btn-home-secondary" %>
      </div>
    </div>
  </section>

  <section class="home-stats">
    <div class="stat-card">
      <strong><%= @users_count %>+</strong>
      <span>builders</span>
    </div>

    <div class="stat-card">
      <strong><%= @projects_count %>+</strong>
      <span>projects</span>
    </div>

    <div class="stat-card">
      <strong><%= @contributors_count %>+</strong>
      <span>contributors</span>
    </div>
  </section>

  <section class="home-featured">
    <div class="section-header">
      <div>
        <h2>Featured projects</h2>
        <p>Discover a few active projects looking for builders.</p>
      </div>

      <%= link_to "Browse all projects", projects_path, class: "btn-home-secondary" %>
    </div>

    <% if @featured_projects.any? %>
      <div class="projects-grid-modern">
        <% @featured_projects.each do |project| %>
          <article class="project-card-modern">
            <div class="project-card-top-modern">
              <span class="badge badge-orange"><%= project.status.capitalize %></span>
              <span class="badge badge-grey"><%= project.category %></span>
            </div>

            <h3 class="project-card-title-modern">
              <%= link_to project.title, project_path(project) %>
            </h3>

            <p class="project-card-text-modern"><%= project.short_description %></p>

            <div class="project-meta-modern">
              <span>⏱ <%= project.estimated_duration.humanize %></span>
              <span>👥 <%= project.accepted_members_count %> / <%= project.max_collaborators %></span>
            </div>

            <div class="tech-list-modern">
              <% if project.technologies.any? %>
                <% project.technologies.each do |technology| %>
                  <span class="tech-badge-modern"><%= technology.name %></span>
                <% end %>
              <% else %>
                <span class="muted-text-modern">No technologies yet</span>
              <% end %>
            </div>

            <div class="project-card-footer-modern">
              <span class="muted-text-modern">
                Owner:
                <strong><%= project.owner&.display_name || "Unknown" %></strong>
              </span>

              <%= link_to "View project", project_path(project), class: "btn btn-grey" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state-modern">
        <h2>No featured projects yet</h2>
        <p>Be the first to create a project on Codemate.</p>

        <% if user_signed_in? %>
          <%= link_to "Create your first project", new_project_path, class: "btn btn-orange w-25 mt-3", style: "background-color: #ff7a00" %>
        <% end %>
      </div>
    <% end %>
  </section>
</div>

<style>
  :root {
    --navy: #0a0f1f;
    --orange: #ff7a00;
    --grey-light: #d1d5db;
    --grey-mid: #9ca3af;
    --white: #ffffff;
  }

  .honk {
    font-family: "Honk", system-ui;
    font-optical-sizing: auto;
    font-weight: 400;
    font-style: normal;
    font-variation-settings:
      "MORF" 15,
      "SHLN" 50;
  }

  .home-shell {
    background: var(--navy);
    min-height: 100vh;
    color: var(--white);
    padding: 48px 40px 64px;
  }

  .home-hero {
    padding: 40px 0 24px;
  }

  .home-hero-content {
    max-width: 760px;
  }

  .home-title {
    font-size: 64px;
    line-height: 1.05;
    margin: 0 0 20px;
    color: var(--orange);
  }

  .home-subtitle {
    font-size: 22px;
    line-height: 1.5;
    color: var(--grey-light);
    margin-bottom: 28px;
    max-width: 680px;
  }

  .home-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-home-primary,
  .btn-home-secondary {
    padding: 14px 22px;
    border-radius: 14px;
    text-decoration: none;
    font-weight: 600;
  }

  .btn-home-primary {
    background: var(--orange);
    color: var(--navy);
  }

  .btn-home-secondary {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.16);
    color: var(--white);
  }

  .home-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(180px, 1fr));
    gap: 20px;
    margin: 36px 0 60px;
  }

  .stat-card {
    background: #11182e;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 18px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stat-card strong {
    font-size: 32px;
    color: var(--orange);
  }

  .stat-card span {
    color: var(--grey-light);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 13px;
  }

  .home-featured {
    margin-top: 10px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 20px;
    margin-bottom: 28px;
  }

  .section-header h2 {
    margin: 0 0 6px;
    font-size: 32px;
  }

  .section-header p {
    margin: 0;
    color: var(--grey-light);
  }

  .projects-grid-modern {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
  }

  .project-card-modern {
    background: #11182e;
    border-radius: 16px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform .2s ease, box-shadow .2s ease;
  }

  .project-card-modern:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .project-card-top-modern {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .badge-orange {
    background: var(--orange);
    color: var(--navy);
    padding: 4px 10px;
    border-radius: 8px;
    font-weight: 600;
  }

  .badge-grey {
    background: var(--grey-mid);
    color: var(--navy);
    padding: 4px 10px;
    border-radius: 8px;
  }

  .project-card-title-modern a {
    color: var(--white);
    text-decoration: none;
    font-size: 22px;
    font-weight: 600;
  }

  .project-card-text-modern {
    color: var(--grey-light);
  }

  .project-meta-modern {
    display: flex;
    justify-content: space-between;
    color: var(--grey-mid);
    gap: 10px;
    flex-wrap: wrap;
  }

  .tech-list-modern {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tech-badge-modern {
    background: rgba(255,255,255,0.1);
    padding: 6px 12px;
    border-radius: 10px;
    color: var(--grey-light);
    font-size: 14px;
  }

  .project-card-footer-modern {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .muted-text-modern {
    color: var(--grey-mid);
  }

  .btn-orange {
    background: var(--orange);
    color: var(--navy) !important;
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
  }

  .btn-grey {
    background: var(--grey-light);
    color: var(--navy) !important;
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
  }

  .empty-state-modern {
    text-align: center;
    padding: 80px 0;
    color: var(--white);
  }

  @media (max-width: 900px) {
    .home-title {
      font-size: 46px;
    }

    .home-stats {
      grid-template-columns: 1fr;
    }

    .section-header {
      flex-direction: column;
      align-items: start;
    }
  }
</style>
