<div class="filters-linear">
  <%= form_with url: projects_path, method: :get, local: true, class: "filters-linear-form" do %>
    <div class="filters-linear-bar">
      <div class="filters-linear-field filters-linear-field--search">
        <%= text_field_tag :q,
          params[:q],
          placeholder: "Search projects...",
          class: "filters-linear-input" %>
      </div>

      <div class="filters-linear-divider"></div>

      <div class="filters-linear-field filters-linear-field--tech">
        <div
          class="filters-linear-tech"
          data-controller="technology-filter"
          data-technology-filter-search-url-value="<%= search_technologies_path %>"
          data-technology-filter-selected-value='<%= (@selected_technologies || []).map { |t| { id: t.id, name: t.name } }.to_json %>'
        >
          <div class="filters-linear-tech-selected" data-technology-filter-target="selected"></div>

          <input
            type="text"
            class="filters-linear-input filters-linear-input--tech"
            placeholder="Add technologies..."
            data-technology-filter-target="input"
            data-action="input->technology-filter#search keydown->technology-filter#handleKeydown"
          >

          <div class="filters-linear-tech-results" data-technology-filter-target="results"></div>
          <div data-technology-filter-target="hiddenFields"></div>
        </div>
      </div>

      <div class="filters-linear-actions">
        <%= submit_tag "Search", class: "filters-linear-submit" %>
      </div>
    </div>

    <details class="filters-linear-advanced">
      <summary class="filters-linear-advanced-summary">Advanced filters</summary>

      <div class="filters-linear-advanced-grid">
        <div class="filters-linear-stack">
          <label class="filters-linear-label">Category</label>
          <select name="category" class="filters-linear-select">
            <option value="">All categories</option>
            <% ["ai", "frontend", "backend", "mobile", "data", "design"].each do |cat| %>
              <option value="<%= cat %>" <%= "selected" if @selected_category == cat %>>
                <%= cat.capitalize %>
              </option>
            <% end %>
          </select>
        </div>

        <div class="filters-linear-stack">
          <label class="filters-linear-label">Duration</label>
          <select name="estimated_duration" class="filters-linear-select">
            <option value="">All durations</option>
            <option value="weekend" <%= "selected" if @selected_duration == "weekend" %>>Weekend</option>
            <option value="one_week" <%= "selected" if @selected_duration == "one_week" %>>One week</option>
            <option value="two_weeks" <%= "selected" if @selected_duration == "two_weeks" %>>Two weeks</option>
            <option value="one_month" <%= "selected" if @selected_duration == "one_month" %>>One month</option>
            <option value="three_months" <%= "selected" if @selected_duration == "three_months" %>>Three months</option>
            <option value="long_term" <%= "selected" if @selected_duration == "long_term" %>>Long term</option>
          </select>
        </div>

        <div class="filters-linear-stack">
          <label class="filters-linear-label">Status</label>
          <select name="status" class="filters-linear-select">
            <option value="">All statuses</option>
            <option value="open" <%= "selected" if @selected_status == "open" %>>Open</option>
            <option value="draft" <%= "selected" if @selected_status == "draft" %>>Draft</option>
            <option value="full" <%= "selected" if @selected_status == "full" %>>Full</option>
          </select>
        </div>
      </div>

      <div class="filters-linear-reset">
        <%= link_to "Reset all filters", projects_path, class: "filters-linear-reset-link" %>
      </div>
    </details>
  <% end %>
</div>
