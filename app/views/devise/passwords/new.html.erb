<div class="auth-card">
  <h2 class="honk text-center mb-4">Forgot your password?</h2>

  <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>

    <%= f.error_notification %>

    <div class="mb-3">
      <%= f.input :email,
                  required: true,
                  autofocus: true,
                  label: "Email",
                  input_html: { autocomplete: "email", class: "form-control" },
                  wrapper_html: { class: "mb-3" },
                  label_html: { class: "form-label" } %>
    </div>

    <%= f.button :submit, "Send me password reset instructions", class: "btn btn-orange w-100 mt-2" %>

  <% end %>

  <div class="auth-links text-center mt-3">
    <%= render "devise/shared/links" %>
  </div>
</div>