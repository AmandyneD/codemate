<div class="project-shell">
  <p class="back-link">
    <%= link_to "← Back to projects", projects_path %>
  </p>

  <section class="project-hero">
    <div>
      <div class="project-badges">
        <span class="badge-status"><%= @project.status.capitalize %></span>
        <span class="badge-category"><%= @project.category.humanize %></span>
      </div>

      <h1 class="project-title title-xl"><%= @project.title %></h1>
      <p class="project-subtitle subtitle"><%= @project.short_description %></p>
    </div>

    <% if @is_owner %>
      <div class="hero-actions">
        <%= link_to "Edit", edit_project_path(@project), class: "btn-outline" %>

        <%= button_to "Delete",
          project_path(@project),
          method: :delete,
          form: { data: { turbo_confirm: "Delete project ?" } },
          class: "btn-orange" %>
      </div>
    <% end %>
  </section>

  <div class="layout">
    <main class="card">
      <section>
        <h2 class="title-lg">About</h2>
        <p><%= @project.description %></p>
      </section>

      <section>
        <h2 class="title-lg">Technologies</h2>

        <div class="tech-list">
          <% if @project.technologies.any? %>
            <% @project.technologies.each do |tech| %>
              <span class="tech-badge"><%= tech.name %></span>
            <% end %>
          <% else %>
            <span class="muted">No technologies yet</span>
          <% end %>
        </div>
      </section>

      <section>
        <h2 class="title-lg">Team</h2>

        <% if @accepted_collaborations.any? %>
          <% @accepted_collaborations.each do |collab| %>
            <div class="member-row">
              <div>
                <strong><%= collab.user.display_name %></strong>

                <% if collab.owner %>
                  <span class="role">Owner</span>
                <% elsif collab.role.present? %>
                  <span class="role"><%= collab.role %></span>
                <% end %>
              </div>

              <% if @is_owner && !collab.owner %>
                <div class="member-actions">
                  <%= button_to "Message",
                    project_conversations_path(@project, recipient_id: collab.user.id),
                    method: :post,
                    class: "btn-outline" %>

                  <%= button_to "Remove",
                    project_collaboration_path(@project, collab),
                    method: :patch,
                    params: { status: "removed" },
                    class: "btn-remove" %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <p class="muted">No team members yet.</p>
        <% end %>
      </section>
    </main>

    <aside class="card">
      <h2 class="title-lg">Project info</h2>

      <ul class="info">
        <li>Owner: <%= @project_owner.display_name %></li>
        <li>Duration: <%= @project.estimated_duration.humanize %></li>
        <li>Team: <%= @project.accepted_members_count %> / <%= @project.max_collaborators %></li>
      </ul>

      <% if user_signed_in? && !@is_owner && @existing_collaboration&.status.in?(%w[pending accepted]) %>
        <%= button_to "Message owner",
          project_conversations_path(@project, recipient_id: @project_owner.id),
          method: :post,
          class: "btn-outline mt-3" %>
      <% end %>

      <% if @project.recruiting? %>
        <div class="callout-green">
          This project is recruiting
        </div>
      <% end %>

      <% if @is_owner %>
        <h2 class="title-lg">Pending</h2>

        <% if @pending_collaborations.any? %>
          <% @pending_collaborations.each do |collab| %>
            <div class="member-row">
              <strong><%= collab.user.display_name %></strong>

              <div class="member-actions">
                <%= button_to "Message",
                  project_conversations_path(@project, recipient_id: collab.user.id),
                  method: :post,
                  class: "btn-outline" %>

                <%= button_to "Accept",
                  project_collaboration_path(@project, collab),
                  method: :patch,
                  params: { status: "accepted" },
                  class: "btn-green" %>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="muted">No pending requests.</p>
        <% end %>
      <% end %>
    </aside>
  </div>
</div>

