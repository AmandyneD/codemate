<div class="page-shell layout-container">
  <div class="page-intro">
    <p class="back-link">
      <%= link_to "← Back to project", project_path(@project) %>
    </p>

    <h1 class="title-xl">Conversation</h1>
    <p class="page-subtitle">
      Discuss the project with <%= @other_user&.display_name || "this collaborator" %>.
    </p>
  </div>

  <div class="profile-layout profile-layout--enhanced">
    <main class="content-card">
      <section class="content-section">
        <div class="section-heading">
          <div>
            <h2 class="title-lg">Messages</h2>
            <p class="muted-text">Keep the discussion focused on the project.</p>
          </div>

          <span class="section-count"><%= @messages.count %></span>
        </div>

        <% if @messages.any? %>
          <div class="conversation-message-list">
            <% @messages.each do |message| %>
              <% mine = message.user == current_user %>

              <article class="conversation-message <%= mine ? "conversation-message--mine" : "conversation-message--other" %>">
                <div class="conversation-message-meta">
                  <strong><%= message.user&.display_name || "Unknown" %></strong>
                  <small class="muted-text"><%= l(message.created_at, format: :short) %></small>
                </div>

                <div class="conversation-message-bubble">
                  <p><%= message.content %></p>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="empty-state">
            <h3 class="title-lg">No messages yet</h3>
            <p class="page-subtitle">Start the conversation and align on the next steps.</p>
          </div>
        <% end %>
      </section>

      <section class="content-section">
        <div class="section-heading">
          <div>
            <h2 class="title-lg">New message</h2>
          </div>
        </div>

        <%= form_with model: [@conversation, @message], local: true, class: "conversation-form" do |f| %>
          <div class="field">
            <%= f.label :content, class: "field-label" %>
            <%= f.text_area :content,
              class: "conversation-textarea",
              placeholder: "Write your message…" %>
          </div>

          <div class="conversation-form-actions">
            <%= f.submit "Send message", class: "btn btn-primary btn-md" %>
          </div>
        <% end %>
      </section>
    </main>

<aside class="sidebar-card conversation-project-sidebar">
  <section class="content-section">
    <% project_status = @project.display_status.presence || "draft" %>

    <div class="conversation-project-header">
      <h2 class="title-lg">Project</h2>

      <span class="badge-status badge-status--<%= project_status %>">
        <%= project_status.capitalize %>
      </span>
    </div>

    <h3 class="dashboard-project-title conversation-project-title">
      <%= @project.title %>
    </h3>

    <p class="dashboard-project-text conversation-project-text">
      <%= @project.short_description.presence || "No short description yet." %>
    </p>

    <div class="project-meta conversation-project-meta">
      <span class="project-meta-item">
        <%= image_tag "icon_cube_W.svg", class: "project-inline-icon", alt: "Category" %>
        <%= @project.category.to_s.humanize %>
      </span>

      <span class="project-meta-item">
        <%= image_tag "icon_planning_W.svg", class: "project-inline-icon", alt: "Duration" %>
        <%= @project.estimated_duration.to_s.humanize %>
      </span>

      <span class="project-meta-item">
        <%= image_tag "icon_user_W.svg", class: "project-inline-icon", alt: "Members" %>
        <%= @project.accepted_members_count %> / <%= @project.max_collaborators %>
      </span>
    </div>

    <div class="tech-list conversation-project-tech-list">
      <% if @project.technologies.any? %>
        <% @project.technologies.each do |technology| %>
          <span class="tech-badge tech-badge--project"><%= technology.name %></span>
        <% end %>
      <% else %>
        <span class="muted-text">No technologies yet</span>
      <% end %>
    </div>

    <div class="conversation-project-owner">
      <span class="muted-text">Owner</span>
      <strong><%= @project.owner&.display_name || "Unknown" %></strong>
    </div>

    <div class="conversation-project-footer">
      <%= link_to "View project", project_path(@project), class: "btn btn-outline btn-sm" %>
    </div>
  </section>
</aside>

  </div>
</div>
