<section class="home-hero-clean" data-controller="home-motion">
  <div
    class="home-hero-bg"
    data-home-motion-target="parallax"
    data-speed="0.18">
  </div>

  <div class="home-hero-overlay"></div>

  <div class="home-hero-inner">
    <h1 class="title-xl home-title-clean" data-home-motion-target="reveal">
      Build real projects.<br>
      Find your dev team.<br>
      Ship faster.
    </h1>

    <p class="subtitle home-subtitle-clean" data-home-motion-target="reveal">
      Join real projects, collaborate with other builders, and create work you can actually showcase.
    </p>

    <div class="home-cta-clean" data-home-motion-target="reveal">
      <% if user_signed_in? %>
      <%= link_to new_project_path, class: "btn btn-primary home-cta-primary glitch-btn" do %>
        <span class="glitch-btn__text" data-text="Start a project">Start a project</span>
      <% end %>
        <%= link_to "Get started", new_user_registration_path, class: "btn btn-primary home-cta-primary" %>
      <% end %>

      <%= link_to "Explore projects", projects_path, class: "btn btn-secondary home-cta-secondary" %>
    </div>
  </div>
</section>

<div class="page-shell home-page layout-container" data-controller="home-motion">

  <section class="home-stats-section" data-home-motion-target="reveal">
    <div class="home-section-intro home-section-intro--stats" data-home-motion-target="reveal">
      <p class="home-section-kicker">Community signal</p>
      <h2 class="title-lg home-section-title">Built by people who actually ship</h2>
      <p class="muted-text home-section-text">
        Codemate is where devs, makers and curious builders meet to turn ideas into real projects.
      </p>
    </div>

    <div class="home-stats-premium">
      <article class="home-stat-card" data-home-motion-target="reveal">
        <div class="home-stat-card-top">
          <%= image_tag "icon_user_W.svg", class: "home-stat-card-icon", alt: "Builders" %>
          <span class="home-stat-card-label">builders</span>
        </div>

        <strong class="home-stat-card-number"><%= @users_count %>+</strong>

        <p class="home-stat-card-text">
          Developers, makers and collaborators building together.
        </p>
      </article>

      <article class="home-stat-card" data-home-motion-target="reveal">
        <div class="home-stat-card-top">
          <%= image_tag "icon_cube_W.svg", class: "home-stat-card-icon", alt: "Projects" %>
          <span class="home-stat-card-label">projects</span>
        </div>

        <strong class="home-stat-card-number"><%= @projects_count %>+</strong>

        <p class="home-stat-card-text">
          Ideas turned into concrete products, MVPs and experiments.
        </p>
      </article>

      <article class="home-stat-card" data-home-motion-target="reveal">
        <div class="home-stat-card-top">
          <%= image_tag "icon_alien_W.svg", class: "home-stat-card-icon", alt: "Contributors" %>
          <span class="home-stat-card-label">contributors</span>
        </div>

        <strong class="home-stat-card-number"><%= @contributors_count %>+</strong>

        <p class="home-stat-card-text">
          People joining forces to design, code and ship faster.
        </p>
      </article>
    </div>
  </section>

  <section class="home-featured-clean" data-home-motion-target="reveal">
    <div class="section-heading home-section-heading" data-home-motion-target="reveal">
      <div>
        <p class="home-section-kicker">Featured builds</p>
        <h2 class="title-lg">Projects looking for builders</h2>
        <p class="muted-text">Discover active projects and jump into something real.</p>
      </div>

      <%= link_to "Browse all", projects_path, class: "btn btn-outline" %>
    </div>

    <% if @featured_projects.any? %>
      <div class="dashboard-grid">
        <% @featured_projects.each do |project| %>
          <article class="dashboard-project-card">
            <div class="dashboard-project-top">
              <span class="badge-status badge-status--<%= project.display_status %>">
                <%= project.display_status.capitalize %>
              </span>
            </div>

            <h3 class="dashboard-project-title">
              <%= link_to project.title, project_path(project) %>
            </h3>

            <p class="dashboard-project-text"><%= project.short_description %></p>

            <div class="project-meta">
              <span class="project-meta-item">
                <%= image_tag "icon_cube_W.svg", class: "project-inline-icon", alt: "Category" %>
                <%= project.category.to_s.humanize %>
              </span>

              <span class="project-meta-item">
                <%= image_tag "icon_planning_W.svg", class: "project-inline-icon", alt: "Duration" %>
                <%= project.estimated_duration.to_s.humanize %>
              </span>

              <span class="project-meta-item">
                <%= image_tag "icon_user_W.svg", class: "project-inline-icon", alt: "Members" %>
                <%= project.accepted_members_count %> / <%= project.max_collaborators %>
              </span>
            </div>

            <div class="tech-list">
              <% if project.technologies.any? %>
                <% project.technologies.each do |technology| %>
                  <span class="tech-badge"><%= technology.name %></span>
                <% end %>
              <% else %>
                <span class="muted-text">No technologies yet</span>
              <% end %>
            </div>

            <div class="dashboard-project-footer">
              <span class="project-card-owner">
                Owner: <strong><%= project.owner&.display_name || "Unknown" %></strong>
              </span>

              <div class="dashboard-project-actions">
                <% if user_signed_in? %>
                  <% bookmark = current_user.bookmarks.find_by(project: project) %>
                  <% if bookmark.present? %>
                    <%= button_to "♥",
                      project_bookmark_path(project, bookmark),
                      method: :delete,
                      class: "btn btn-orange",
                      form: { data: { turbo_confirm: "Remove this project from favorites?" } } %>
                  <% else %>
                    <%= button_to "♡",
                      project_bookmarks_path(project),
                      method: :post,
                      class: "btn btn-outline" %>
                  <% end %>
                <% end %>

                <%= link_to "View", project_path(project), class: "btn btn-outline" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state home-empty-state" data-home-motion-target="reveal">
        <h3 class="title-lg">No featured projects yet</h3>
        <p class="subtitle">Be the first to create a project.</p>

        <% if user_signed_in? %>
          <%= link_to "Create your first project", new_project_path, class: "btn btn-primary mt-3" %>
        <% end %>
      </div>
    <% end %>
  </section>

  <section class="home-final-banner" data-home-motion-target="reveal">
    <div class="home-final-banner-inner">
      <div class="home-final-banner-content">
        <p class="home-section-kicker home-final-banner-kicker">Start building</p>

        <h2 class="title-xl home-final-banner-title">
          Your next real project can start here.
        </h2>

        <p class="home-final-banner-text">
          Launch an idea, find contributors, and build something worth showing.
        </p>
      </div>

      <div class="home-final-banner-actions">
        <% if user_signed_in? %>
          <%= link_to "Create a project", new_project_path, class: "btn btn-primary home-final-banner-primary" %>
        <% else %>
          <%= link_to "Join Codemate", new_user_registration_path, class: "btn btn-primary home-final-banner-primary" %>
        <% end %>

        <%= link_to "Explore projects", projects_path, class: "btn btn-secondary home-final-banner-secondary" %>
      </div>
    </div>
  </section>

</div>
