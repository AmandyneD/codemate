<div class="page-shell">
  <p class="back-link">
    <%= link_to "← Back", request.referer.presence || projects_path %>
  </p>

  <section class="project-hero">
    <div>
      <h1><%= @user.display_name %></h1>
      <p class="page-subtitle">
        <%= @user.bio.presence || "This member has not added a bio yet." %>
      </p>
    </div>

    <% if user_signed_in? && current_user == @user %>
      <%= link_to "Edit profile", edit_user_path(@user), class: "btn btn-primary" %>
    <% end %>
  </section>

  <div class="project-layout">
    <main class="content-card">
      <% if @user.avatar_url.present? %>
        <section class="content-section">
          <h2>Profile picture</h2>
          <img src="<%= @user.avatar_url %>" alt="<%= @user.display_name %>" class="profile-avatar">
        </section>
      <% end %>

      <section class="content-section">
        <h2>Technologies</h2>
        <div class="tech-list">
          <% if @user.technologies.any? %>
            <% @user.technologies.order(:name).each do |technology| %>
              <span class="tech-badge"><%= technology.name %></span>
            <% end %>
          <% else %>
            <span class="muted-text">No technologies added yet.</span>
          <% end %>
        </div>
      </section>

      <section class="content-section">
        <h2>Created projects</h2>
        <% if @owned_projects.any? %>
          <div class="member-list">
            <% @owned_projects.each do |project| %>
              <%= link_to project_path(project), class: "member-card member-card-link" do %>
                <div>
                  <strong><%= project.title %></strong>
                  <div class="muted-text"><%= project.short_description %></div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="muted-text">No created projects yet.</p>
        <% end %>
      </section>

      <section class="content-section">
        <h2>Joined projects</h2>
        <% if @joined_projects.any? %>
          <div class="member-list">
            <% @joined_projects.each do |project| %>
              <%= link_to project_path(project), class: "member-card member-card-link" do %>
                <div>
                  <strong><%= project.title %></strong>
                  <div class="muted-text"><%= project.short_description %></div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="muted-text">No joined projects yet.</p>
        <% end %>
      </section>
    </main>

    <aside class="sidebar-card">
      <h2>Profile info</h2>

      <ul class="info-list">
        <li><strong>Name:</strong> <%= @user.display_name %></li>
        <li><strong>Email:</strong> <%= @user.email %></li>

        <% if @user.github_url.present? %>
          <li>
            <strong>GitHub:</strong>
            <%= link_to @user.github_url, @user.github_url, target: "_blank", rel: "noopener" %>
          </li>
        <% end %>

        <li><strong>Projects created:</strong> <%= @owned_projects.count %></li>
        <li><strong>Projects joined:</strong> <%= @joined_projects.count %></li>
      </ul>
    </aside>
  </div>
</div>
