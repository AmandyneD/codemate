<div class="auth-page">
  <div class="auth-card">
    <h1>Edit profile</h1>
    <p class="auth-subtitle">Update your public profile and account settings.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-section">
        <h2>Public profile</h2>

        <div class="field">
          <%= f.label :display_name %>
          <%= f.text_field :display_name, autocomplete: "nickname" %>
        </div>

        <div class="field">
          <%= f.label :bio %>
          <%= f.text_area :bio, rows: 4 %>
        </div>

        <div class="field">
          <%= f.label :github_url %>
          <%= f.url_field :github_url, placeholder: "https://github.com/yourname" %>
        </div>

        <div class="field">
          <%= f.label :avatar_url %>
          <%= f.url_field :avatar_url, placeholder: "https://..." %>
        </div>

        <div class="field">
          <%= f.label :stack_summary %>
          <%= f.text_field :stack_summary, placeholder: "Rails, PostgreSQL, JavaScript..." %>
        </div>
      </div>

      <div class="form-section">
        <h2>Account</h2>

        <div class="field">
          <%= f.label :email %>
          <%= f.email_field :email, autocomplete: "email" %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="helper-text">
            Currently waiting confirmation for: <%= resource.unconfirmed_email %>
          </p>
        <% end %>
      </div>

      <div class="form-section">
        <h2>Change password</h2>
        <p class="helper-text">Leave these fields blank if you do not want to change your password.</p>

        <div class="field">
          <%= f.label :password %>
          <%= f.password_field :password, autocomplete: "new-password" %>
          <% if @minimum_password_length %>
            <small class="helper-text"><%= @minimum_password_length %> characters minimum</small>
          <% end %>
        </div>

        <div class="field">
          <%= f.label :password_confirmation %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
        </div>

        <div class="field">
          <%= f.label :current_password %>
          <%= f.password_field :current_password, autocomplete: "current-password" %>
          <small class="helper-text">Required to save changes.</small>
        </div>
      </div>

      <div class="actions">
        <%= f.submit "Save changes", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>

  <div class="danger-card">
    <h2>Danger zone</h2>
    <p>If you no longer want to use Codemate, you can delete your account.</p>

    <%= button_to "Delete my account",
      registration_path(resource_name),
      data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
      method: :delete,
      class: "btn btn-danger" %>
  </div>
</div>
