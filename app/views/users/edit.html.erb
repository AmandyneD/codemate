<div class="page-shell profile-edit-page">
  <p class="back-link">
    <%= link_to "← Back to profile", user_path(@user) %>
  </p>

  <div class="page-header">
    <div>
      <h1 class="title-xl">Edit profile</h1>
      <p class="page-subtitle">Update your public profile and technologies.</p>
    </div>
  </div>

  <section class="profile-hero-card profile-edit-hero">
    <div class="profile-hero-main">
      <div class="profile-avatar-wrap">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "profile-avatar-large", alt: @user.display_name %>
        <% else %>
          <div class="profile-avatar-fallback">
            <%= @user.display_name.to_s.first.upcase %>
          </div>
        <% end %>
      </div>

      <div class="profile-hero-content">
        <h2 class="title-lg"><%= @user.display_name %></h2>
        <p class="muted-text">Editing your public profile</p>
      </div>
    </div>
  </section>

  <div class="auth-card profile-edit-card">
    <%= form_with model: @user, html: { multipart: true } do |f| %>

      <% if @user.errors.any? %>
        <div class="form-errors">
          <h2 class="title-md"><%= pluralize(@user.errors.count, "error") %> prevented this profile from being saved:</h2>
          <ul>
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <section class="content-section">
        <h2 class="title-lg">Public profile</h2>

        <div class="field">
          <%= f.label :display_name, "Display name" %>
          <%= f.text_field :display_name %>
        </div>

        <div class="field">
          <%= f.label :bio, "Bio" %>
          <%= f.text_area :bio, rows: 4, placeholder: "Tell other members a bit about yourself, your background, or what you like to build." %>
        </div>

        <div class="field">
          <%= f.label :github_url, "GitHub URL" %>
          <%= f.text_field :github_url, placeholder: "https://github.com/yourname" %>
        </div>
      </section>

      <section class="content-section profile-edit-subcard">
        <h2 class="title-lg">Technologies</h2>
        <p class="muted-text">Select the technologies you use so other members can better understand your stack.</p>

        <%= hidden_field_tag "user[technology_ids][]", "" %>

        <div class="tech-grid">
          <% Technology.order(:name).each do |tech| %>
            <label class="tech-option" for="user_technology_<%= tech.id %>">
              <%= check_box_tag "user[technology_ids][]",
                tech.id,
                @user.technology_ids.include?(tech.id),
                id: "user_technology_#{tech.id}" %>
              <span><%= tech.name %></span>
            </label>
          <% end %>
        </div>
      </section>

      <% if @user.avatar.attached? %>
        <div class="field">
          <label>Current avatar</label>
          <div class="avatar-preview">
            <%= image_tag @user.avatar, class: "profile-avatar" %>
          </div>
        </div>
      <% end %>

      <div class="field">
        <%= f.label :avatar, "Avatar" %>
        <%= f.file_field :avatar, accept: "image/*" %>
      </div>

      <div class="actions">
        <%= f.submit "Save profile", class: "btn btn-primary w-100" %>
      </div>

    <% end %>
  </div>
</div>
