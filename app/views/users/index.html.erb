<div class="page-shell-modern">
  <div class="page-header-modern">
    <div>
      <h1 class="page-title honk">Browse builders</h1>
      <p class="page-subtitle-modern">
        Discover profiles and find people by stack.
      </p>
    </div>
  </div>

  <div class="search-hero">
    <%= form_with url: users_path, method: :get, local: true, class: "project-search-bar" do %>
      <div class="search-input-wrap">
        <%= text_field_tag :q,
            params[:q],
            placeholder: "Search builders...",
            class: "search-input" %>
        <span class="search-input-icon">⌕</span>
      </div>

      <%= select_tag :stack,
          options_for_select(
            [["All stacks", ""]] + Technology::CATEGORIES.map { |category| [category.humanize, category] },
            params[:stack]
          ),
          class: "search-select" %>

      <%= submit_tag "Search", class: "search-submit" %>
    <% end %>
  </div>

  <% if @users.any? %>
    <div class="projects-grid-modern">
      <% @users.each do |user| %>
        <article class="project-card-modern">
          <div class="d-flex align-items-center gap-3">
            <% if user.avatar.attached? %>
              <%= image_tag user.avatar, class: "builder-avatar", alt: user.display_name %>
            <% else %>
              <div class="builder-avatar-fallback">
                <%= user.display_name.to_s.first&.upcase || "?" %>
              </div>
            <% end %>

            <div>
              <h2 class="project-card-title-modern mb-1">
                <%= link_to(user.display_name.presence || "Anonymous", user_path(user)) %>
              </h2>
              <p class="muted-text-modern mb-0">
                <%= user.github_url.present? ? user.github_url.gsub("https://", "").gsub("http://", "") : "No GitHub yet" %>
              </p>
            </div>
          </div>

          <p class="project-card-text-modern">
            <%= truncate(user.bio.presence || "No bio yet.", length: 120) %>
          </p>

          <div class="tech-list-modern">
            <% if user.technologies.any? %>
              <% user.technologies.each do |technology| %>
                <span class="tech-badge-modern"><%= technology.name %></span>
              <% end %>
            <% else %>
              <span class="muted-text-modern">No technologies yet</span>
            <% end %>
          </div>

          <div class="project-card-footer-modern">
            <span class="muted-text-modern">
              <%= pluralize(user.technologies.count, "tech") %>
            </span>

            <%= link_to "View profile", user_path(user), class: "btn btn-grey" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state-modern">
      <h2>No builders found</h2>
      <p>Try another search or stack filter.</p>
    </div>
  <% end %>
</div>

<style>
  :root {
    --navy: #0a0f1f;
    --orange: #ff7a00;
    --grey-light: #d1d5db;
    --grey-mid: #9ca3af;
    --white: #ffffff;
  }

  .honk {
    font-family: "Honk", system-ui;
    font-optical-sizing: auto;
    font-weight: 400;
    font-style: normal;
    font-variation-settings:
      "MORF" 15,
      "SHLN" 50;
  }

  .page-shell-modern {
    background: var(--navy);
    min-height: 100vh;
    padding: 40px;
    color: var(--white);
  }

  .page-header-modern {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }

  .page-title {
    font-size: 48px;
    margin: 0;
    color: var(--orange);
  }

  .page-subtitle-modern {
    color: var(--grey-light);
    margin-top: 6px;
  }

  .projects-grid-modern {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
  }

  .project-card-modern {
    background: #11182e;
    border-radius: 16px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform .2s ease, box-shadow .2s ease;
  }

  .project-card-modern:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .project-card-title-modern a {
    color: var(--white);
    text-decoration: none;
    font-size: 22px;
    font-weight: 600;
  }

  .project-card-text-modern {
    color: var(--grey-light);
  }

  .tech-list-modern {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tech-badge-modern {
    background: rgba(255,255,255,0.1);
    padding: 6px 12px;
    border-radius: 10px;
    color: var(--grey-light);
    font-size: 14px;
  }

  .project-card-footer-modern {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .muted-text-modern {
    color: var(--grey-mid);
  }

  .btn-grey {
    background: var(--grey-light);
    color: var(--navy) !important;
    padding: 10px 20px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
  }

  .empty-state-modern {
    text-align: center;
    padding: 80px 0;
    color: var(--white);
  }

  .builder-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }

  .builder-avatar-fallback {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--orange);
    color: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 22px;
  }
</style>
