<div class="home-shell">

  <!-- HERO -->
  <section class="home-hero">
    <div class="home-hero-content">

      <h1 class="home-title honk">
        Build real projects.<br>
        Find your dev team.<br>
        Ship faster.
      </h1>

      <p class="home-subtitle">
        Join real projects, collaborate with other builders, and create work you can actually showcase.
      </p>

      <div class="home-cta">
        <% if user_signed_in? %>
          <%= link_to "Start a project", new_project_path, class: "btn-home-primary" %>
        <% else %>
          <%= link_to "Get started", new_user_registration_path, class: "btn-home-primary" %>
        <% end %>

        <%= link_to "Browse projects", projects_path, class: "btn-home-secondary" %>
      </div>

    </div>
  </section>

  <!-- STATS -->
  <section class="home-stats">
    <div class="stat-card">
      <strong><%= @users_count %>+</strong>
      <span>builders</span>
    </div>

    <div class="stat-card">
      <strong><%= @projects_count %>+</strong>
      <span>projects</span>
    </div>

    <div class="stat-card">
      <strong><%= @contributors_count %>+</strong>
      <span>contributors</span>
    </div>
  </section>

  <!-- FEATURED PROJECTS -->
  <section class="home-featured">

    <div class="section-header">
      <div>
        <h2>Featured projects</h2>
        <p>Discover a few active projects looking for builders.</p>
      </div>

      <%= link_to "Browse all projects", projects_path, class: "btn-home-secondary" %>
    </div>

    <% if @featured_projects.any? %>

      <div class="projects-grid-modern">

        <% @featured_projects.each do |project| %>
          <article class="project-card-modern">

            <!-- Badges -->
            <div class="project-card-top-modern">
              <span class="badge-orange"><%= project.status.capitalize %></span>
              <span class="badge-grey"><%= project.category %></span>
            </div>

            <!-- Title -->
            <h3 class="project-card-title-modern">
              <%= link_to project.title, project_path(project) %>
            </h3>

            <!-- Description -->
            <p class="project-card-text-modern"><%= project.short_description %></p>

            <!-- Meta -->
            <div class="project-meta-modern">
              <span>⏱ <%= project.estimated_duration.humanize %></span>
              <span>👥 <%= project.accepted_members_count %> / <%= project.max_collaborators %></span>
            </div>

            <!-- Technologies -->
            <div class="tech-list-modern">
              <% if project.technologies.any? %>
                <% project.technologies.each do |technology| %>
                  <span class="tech-badge-modern"><%= technology.name %></span>
                <% end %>
              <% else %>
                <span class="muted-text-modern">No technologies yet</span>
              <% end %>
            </div>

            <!-- Footer -->
            <div class="project-card-footer-modern">
              <span class="muted-text-modern">
                Owner:
                <strong><%= project.owner&.display_name || "Unknown" %></strong>
              </span>

              <%= link_to "View project", project_path(project), class: "btn btn-grey" %>
            </div>

          </article>
        <% end %>

      </div>

    <% else %>

      <div class="empty-state-modern">
        <h2>No featured projects yet</h2>
        <p>Be the first to create a project on Codemate.</p>

        <% if user_signed_in? %>
          <%= link_to "Create your first project", new_project_path, class: "btn btn-orange mt-3" %>
        <% end %>
      </div>

    <% end %>

  </section>

</div>