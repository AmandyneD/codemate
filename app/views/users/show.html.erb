<div class="page-shell">
  <p class="back-link">
    <%= link_to "← Back", request.referer.presence || projects_path %>
  </p>

  <section class="profile-hero-card">
    <div class="profile-hero-main">
      <div class="profile-avatar-wrap">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "profile-avatar profile-avatar-large" %>
        <% else %>
          <div class="profile-avatar-fallback">
            <%= @user.display_name.to_s.first.upcase %>
          </div>
        <% end %>
      </div>

      <div class="profile-hero-content">
        <h1><%= @user.display_name %></h1>

        <p class="page-subtitle">
          <%= @user.bio.presence || "This member has not added a bio yet." %>
        </p>

        <div class="profile-meta">
          <% if @user.github_url.present? %>
            <span>
              <strong>GitHub:</strong>
              <%= link_to @user.github_url, @user.github_url, target: "_blank", rel: "noopener" %>
            </span>
          <% end %>

          <span><strong><%= @owned_projects.count %></strong> created</span>
          <span><strong><%= @joined_projects.count %></strong> joined</span>
        </div>
      </div>
    </div>

    <% if user_signed_in? && current_user == @user %>
      <div class="profile-hero-actions">
        <%= link_to "Edit profile", edit_user_path(@user), class: "btn btn-primary" %>
      </div>
    <% end %>
  </section>

  <div class="profile-layout">
    <main class="content-card">
      <section class="content-section">
        <div class="section-heading">
          <h2>Technologies</h2>
        </div>

        <div class="tech-list">
          <% if @user.technologies.any? %>
            <% @user.technologies.order(:name).each do |technology| %>
              <span class="tech-badge"><%= technology.name %></span>
            <% end %>
          <% else %>
            <span class="muted-text">No technologies added yet.</span>
          <% end %>
        </div>
      </section>

      <section class="content-section">
        <div class="section-heading">
          <h2>Created projects</h2>
          <span class="section-count"><%= @owned_projects.count %></span>
        </div>

        <% if @owned_projects.any? %>
          <div class="project-list">
            <% @owned_projects.each do |project| %>
              <%= link_to project_path(project), class: "project-row-card" do %>
                <div class="project-row-card-content">
                  <div class="project-row-card-main">
                    <strong><%= project.title %></strong>
                    <div class="muted-text"><%= project.short_description %></div>
                  </div>

                  <div class="project-row-card-meta">
                    <span class="badge"><%= project.status.capitalize %></span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="muted-text">No created projects yet.</p>
        <% end %>
      </section>

      <section class="content-section">
        <div class="section-heading">
          <h2>Joined projects</h2>
          <span class="section-count"><%= @joined_projects.count %></span>
        </div>

        <% if @joined_projects.any? %>
          <div class="project-list">
            <% @joined_projects.each do |project| %>
              <%= link_to project_path(project), class: "project-row-card" do %>
                <div class="project-row-card-content">
                  <div class="project-row-card-main">
                    <strong><%= project.title %></strong>
                    <div class="muted-text"><%= project.short_description %></div>
                  </div>

                  <div class="project-row-card-meta">
                    <span class="badge"><%= project.status.capitalize %></span>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="muted-text">No joined projects yet.</p>
        <% end %>
      </section>

      <section class="content-section">
  <div class="section-heading">
    <h2>Favorite projects</h2>
    <span class="section-count"><%= @favorite_projects.count %></span>
  </div>

<section class="content-section">
  <div class="section-heading">
    <h2>Favorite projects</h2>
    <span class="section-count"><%= @favorite_projects.count %></span>
  </div>

    <% if @favorite_projects.any? %>
      <div class="project-list">
        <% @favorite_projects.each do |project| %>
          <%= link_to project_path(project), class: "project-row-card" do %>
            <div class="project-row-card-content">
              <div class="project-row-card-main">
                <strong><%= project.title %></strong>
                <div class="muted-text"><%= project.short_description %></div>
              </div>

              <div class="project-row-card-meta">
                <span class="badge"><%= project.status.capitalize %></span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="muted-text">No favorite projects yet.</p>
    <% end %>
  </section>

    </main>

    <aside class="sidebar-card">
      <h2>Profile info</h2>

      <ul class="info-list">
        <li><strong>Name:</strong> <%= @user.display_name %></li>
        <li><strong>Email:</strong> <%= @user.email %></li>

        <% if @user.github_url.present? %>
          <li>
            <strong>GitHub:</strong>
            <%= link_to "View profile", @user.github_url, target: "_blank", rel: "noopener" %>
          </li>
        <% end %>

        <li><strong>Projects created:</strong> <%= @owned_projects.count %></li>
        <li><strong>Projects joined:</strong> <%= @joined_projects.count %></li>
        <li><strong>Technologies:</strong> <%= @user.technologies.count %></li>
      </ul>
    </aside>
  </div>
</div>
